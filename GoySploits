local function sfStopWalk()
	if sf.walkConn then sf.walkConn:Disconnect() sf.walkConn=nil end sf.walkMoving=false
	if sf.walkAnim and sf.walkAnim.IsPlaying then sf.walkAnim:Stop() end sf.walkAnim=nil
	local c=sfChar() local h=sfHRP() if c and c:FindFirstChild("Humanoid") and h then c.Humanoid:MoveTo(h.Position) end
end
local function sfWalkTo(p)
	if sf.walkConn then sf.walkConn:Disconnect() sf.walkConn=nil end sf.walkMoving=true
	local c=sfChar() local hum=c and c:FindFirstChild("Humanoid") if not hum then sf.walkMoving=false return end
	if not (sf.walkAnim and sf.walkAnim.IsPlaying) then
		local a2=hum:FindFirstChildOfClass("Animator") if a2 then local an=Instance.new("Animation") an.AnimationId="rbxassetid://913376220" sf.walkAnim=a2:LoadAnimation(an) sf.walkAnim.Priority=Enum.AnimationPriority.Action sf.walkAnim.Looped=true sf.walkAnim:Play() end
	end
	sf.walkConn=RunService.Heartbeat:Connect(function()
		if not sf.walkMoving then sf.walkConn:Disconnect() sf.walkConn=nil return end
		local pC=p.Character if not pC then sf.walkMoving=false return end local pH=pC:FindFirstChild("HumanoidRootPart") if not pH then sf.walkMoving=false return end
		local h2=sfChar() and sfChar():FindFirstChild("Humanoid") if h2 then h2:MoveTo(pH.Position) end
	end)
end
local function stopSlapFarm()
	sf.active=false sf.flightOn=false sf.target=nil sf.lastTarget=nil sfStopWalk()
	if sf.flightConn then sf.flightConn:Disconnect() sf.flightConn=nil end if sf.stepConn then sf.stepConn:Disconnect() sf.stepConn=nil end
	local c=sfChar() if c then sfFlight(c,false) if c:FindFirstChild("Humanoid") then c.Humanoid:MoveTo(c.HumanoidRootPart and c.HumanoidRootPart.Position or Vector3.new()) end end
	sf.speedSlider=nil sf.speedBox=nil sf.speedKnob=nil
end
local function startSlapFarm()
	sf.active=true
	sf.flightConn=RunService.RenderStepped:Connect(function()
		if sf.walkMode then return end local hrp=sfHRP() if not hrp or not sf.flightOn then return end
		local vel=hrp:FindFirstChild("SFFlightVelocity") local gyro=hrp:FindFirstChild("SFFlightGyro") if not vel or not gyro then return end
		if sf.target and sf.target.Character and sf.target.Character:FindFirstChild("HumanoidRootPart") then
			local tH=sf.target.Character.HumanoidRootPart local diff=(tH.Position+Vector3.new(0,10,0))-hrp.Position local dist=diff.Magnitude
			if dist>1 then vel.Velocity=diff.Unit*math.min(dist*20,sf.speed) else vel.Velocity=Vector3.new(0,0,0) end gyro.CFrame=CFrame.new(hrp.Position,tH.Position)
		else vel.Velocity=Vector3.new(0,0,0) gyro.CFrame=CFrame.new(hrp.Position) end
	end)
	sf.stepConn=RunService.Stepped:Connect(function()
		local c=sfChar() if c and sf.flightOn and not sf.walkMode then for _,p in pairs(c:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end end
	end)
	task.spawn(function()
		while sf.active do
			task.wait(0.1) local c=sfChar() local hrp=sfHRP() local toolEx=sfHasTool()
			if sf.walkMode then
				if not toolEx then sfStopWalk() if hrp then safeTeleportCFrame(SPAWN_CF) end continue end
				local tool=c and c:FindFirstChildOfClass("Tool") local myT=tool or Player.Backpack:FindFirstChildOfClass("Tool")
				if not tool and myT and c and c:FindFirstChild("Humanoid") then c.Humanoid:EquipTool(myT) task.wait(0.1) tool=c:FindFirstChildOfClass("Tool") end
				local tgts=sfTargets() if #tgts==0 then sfStopWalk() continue end
				local p=tgts[1] if not sfFilters(p) then sfStopWalk() continue end
				sf.lastTarget=p sf.target=p sfWalkTo(p)
				local timeout=tick()+5
				repeat task.wait(0.05) if not sf.active or not sf.walkMode then break end
					local pH=p.Character and p.Character:FindFirstChild("HumanoidRootPart") if not pH or not sfFilters(p) then break end if hrp and (pH.Position-hrp.Position).Magnitude<6 then break end
				until tick()>timeout
				if sf.walkConn then sf.walkConn:Disconnect() sf.walkConn=nil end sf.walkMoving=false
				tool=c and c:FindFirstChildOfClass("Tool")
				if tool then tool:Activate() if sf.antiKick then task.wait(1) else task.wait(0.1) end end
				sf.target=nil
			else
				sfStopWalk()
				if not toolEx then if sf.flightOn then sf.flightOn=false sf.target=nil sfFlight(c,false) end if hrp then safeTeleportCFrame(SPAWN_CF) end continue end
				if not sf.flightOn then sf.flightOn=true sfFlight(c,true) end
				local tool=c and c:FindFirstChildOfClass("Tool") local myT=tool or Player.Backpack:FindFirstChildOfClass("Tool") if not tool and myT then c.Humanoid:EquipTool(myT) task.wait(0.1) end
				local tgts=sfTargets() if #tgts==0 then sf.target=nil continue end
				for _,p in pairs(tgts) do
					if not sfFilters(p) then continue end sf.target=p sf.lastTarget=p local fe=tick()+2
					while tick()<fe do
						if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then break end if not sfFilters(p) then sf.target=nil break end
						tool=c and c:FindFirstChildOfClass("Tool") if tool then tool:Activate() task.wait(sf.antiKick and 1 or 0.1) else break end
					end
				end sf.target=nil
			end
		end
	end)
end
