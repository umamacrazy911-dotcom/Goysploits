-- =====================
-- INVISIBILITY — faithful to original, all logic gated by invisActive
-- =====================
local invisActive = false
local invisConnections = {}

local function stopInvisibility()
	invisActive = false
	for _, c in ipairs(invisConnections) do pcall(function() c:Disconnect() end) end
	invisConnections = {}
end

local function startInvisibility()
	-- Slap check
	local ls = Player:FindFirstChild("leaderstats")
	local slaps = ls and ls:FindFirstChild("Slaps")
	local slapCount = slaps and slaps.Value or 0
	if slapCount < 666 then
		showToast("Need 666 slaps! You have "..slapCount, THEME.RED)
		states["Invisibility"] = false
		if tileRefs["Invisibility"] then tileRefs["Invisibility"](false) end
		return
	end

	invisActive = true

	-- These are session-local, just like the original standalone script
	local event  = game.ReplicatedStorage:WaitForChild("Ghostinvisibilityactivated",  5)
	local event1 = game.ReplicatedStorage:WaitForChild("Ghostinvisibilitydeactivated", 5)
	if not event or not event1 then
		showToast("Ghost events not found", THEME.RED)
		stopInvisibility()
		states["Invisibility"] = false
		if tileRefs["Invisibility"] then tileRefs["Invisibility"](false) end
		return
	end

	local plr   = Player
	local firsttime = true

	local currentglove = plr:WaitForChild("leaderstats").Glove.Value
	local glovecd      = workspace.Lobby:FindFirstChild(currentglove) and workspace.Lobby:FindFirstChild(currentglove):FindFirstChildOfClass("ClickDetector")
	local ghostcd      = workspace.Lobby.Ghost.ClickDetector

	-- QuickRespawn identical to original — returns a RefreshCharacter function
	local function QuickRespawn()
		local isRefreshing = false
		local function RefreshCharacter(callback)
			if isRefreshing then return end
			isRefreshing = true
			local character = plr.Character
			if not character then isRefreshing = false return end
			local rootPart = character:FindFirstChild("HumanoidRootPart")
			local savedCFrame = rootPart and rootPart.CFrame or CFrame.new(0,5,0)
			local savedCameraCFrame = workspace.CurrentCamera.CFrame
			task.spawn(function()
				local humanoid = character:FindFirstChildWhichIsA("Humanoid")
				if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Dead) end
				character:ClearAllChildren()
				local tempModel = Instance.new("Model") tempModel.Name="TempRefreshModel" tempModel.Parent=workspace
				plr.Character = tempModel task.wait() plr.Character = character tempModel:Destroy()
				local newCharacter = plr.CharacterAdded:Wait()
				local newRoot = newCharacter:WaitForChild("HumanoidRootPart", 5)
				if newRoot then newRoot.CFrame = savedCFrame workspace.CurrentCamera.CFrame = savedCameraCFrame end
				if callback then task.defer(callback, newCharacter) end
				isRefreshing = false
			end)
		end
		return RefreshCharacter
	end

	local function TurnInvisible()
		if not invisActive then return end
		QuickRespawn()  -- call the outer function, returning RefreshCharacter, then immediately invoke it
		-- re-read glove cd in case glove changed
		currentglove = plr:WaitForChild("leaderstats").Glove.Value
		local gm = workspace.Lobby:FindFirstChild(currentglove)
		if gm then
			local cd = gm:FindFirstChildOfClass("ClickDetector")
			if not cd then for _,d in pairs(gm:GetDescendants()) do if d:IsA("ClickDetector") then cd=d break end end end
			if cd then glovecd = cd end
		end
		if not invisActive then return end
		fireclickdetector(ghostcd)
		event:FireServer()
		if glovecd then fireclickdetector(glovecd) end
	end

	local function AutoUnEquip()
		if not invisActive then return end
		if firsttime then
			local t = plr.Character and plr.Character:FindFirstChildOfClass("Tool")
			if t then t.Parent = plr.Backpack end
			firsttime = false
		end
	end

	-- Wire CharacterAdded (only active while invisActive)
	local charConn = plr.CharacterAdded:Connect(function(newChar)
		if not invisActive then return end
		firsttime = true
		task.wait(0.5)
		if not invisActive then return end
		TurnInvisible()
		-- Wire new char's ChildAdded
		local c2 = newChar.ChildAdded:Connect(function(child)
			if not invisActive then return end
			if child:IsA("Tool") then task.wait(0.01) AutoUnEquip() end
		end)
		table.insert(invisConnections, c2)
	end)
	table.insert(invisConnections, charConn)

	-- Wire current char's ChildAdded
	local char = plr.Character
	if char then
		local c3 = char.ChildAdded:Connect(function(child)
			if not invisActive then return end
			if child:IsA("Tool") then task.wait(0.01) AutoUnEquip() end
		end)
		table.insert(invisConnections, c3)
	end

	-- First activation
	TurnInvisible()
end

