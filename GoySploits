-- Minimize Helper
-- =====================
local function addMinimizeButton(frame, titleBar, contentItems, titleBarPixelHeight)
	titleBarPixelHeight = titleBarPixelHeight or 28
	local minBtn = Instance.new("TextButton")
	minBtn.Size = UDim2.new(0, 18, 0, 18)
	minBtn.Position = UDim2.new(1, -3, 0, 5)
	minBtn.AnchorPoint = Vector2.new(1, 0)
	minBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
	minBtn.Text = "−"
	minBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
	minBtn.TextScaled = true
	minBtn.Font = Enum.Font.GothamBold
	minBtn.ZIndex = (frame.ZIndex or 10) + 5
	minBtn.Parent = frame
	local minBtnCorner = Instance.new("UICorner")
	minBtnCorner.CornerRadius = UDim.new(0.3, 0)
	minBtnCorner.Parent = minBtn
	local minimized = false
	local originalSize = frame.Size
	minBtn.MouseButton1Click:Connect(function()
		minimized = not minimized
		if minimized then
			minBtn.Text = "+"
			frame.Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, titleBarPixelHeight)
			for _, c in ipairs(contentItems) do
				if c and c ~= titleBar and c ~= minBtn and c.Parent == frame then c.Visible = false end
			end
		else
			minBtn.Text = "−"
			frame.Size = originalSize
			for _, c in ipairs(contentItems) do
				if c and c.Parent == frame then c.Visible = true end
			end
		end
	end)
	return minBtn
end

