-- Invisibility
-- =====================
local invisActive=false
local invisCharConn=nil
local invisToolConn=nil

local function stopInvisibility()
	invisActive=false
	if invisCharConn then invisCharConn:Disconnect() invisCharConn=nil end
	if invisToolConn then invisToolConn:Disconnect() invisToolConn=nil end
end

local function startInvisibility()
	-- Check slap count
	local ls=Player:FindFirstChild("leaderstats")
	local slaps=ls and ls:FindFirstChild("Slaps")
	if not slaps or slaps.Value < 666 then
		showToast("Need 666 slaps to use Invisibility!",Color3.fromRGB(200,80,80))
		states["Invisibility"]=false
		if tileRefs["Invisibility"] then tileRefs["Invisibility"](false) end
		return
	end

	invisActive=true

	local event=game.ReplicatedStorage:FindFirstChild("Ghostinvisibilityactivated")
	local event1=game.ReplicatedStorage:FindFirstChild("Ghostinvisibilitydeactivated")
	if not event or not event1 then
		showToast("Invisibility events not found!",Color3.fromRGB(200,80,80))
		stopInvisibility()
		states["Invisibility"]=false
		if tileRefs["Invisibility"] then tileRefs["Invisibility"](false) end
		return
	end

	local firsttime=true

	local function QuickRespawn()
		local isRefreshing=false
		local function RefreshCharacter(callback)
			if isRefreshing then return end
			isRefreshing=true
			local character=Player.Character
			if not character then isRefreshing=false return end
			local rootPart=character:FindFirstChild("HumanoidRootPart")
			local savedCFrame=rootPart and rootPart.CFrame or CFrame.new(0,5,0)
			local savedCameraCFrame=workspace.CurrentCamera.CFrame
			task.spawn(function()
				local humanoid=character:FindFirstChildWhichIsA("Humanoid")
				if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Dead) end
				character:ClearAllChildren()
				local tempModel=Instance.new("Model") tempModel.Name="TempRefreshModel" tempModel.Parent=workspace
				Player.Character=tempModel task.wait()
				Player.Character=character tempModel:Destroy()
				local newCharacter=Player.CharacterAdded:Wait()
				local newHumanoid=newCharacter:WaitForChild("Humanoid",5)
				local newRoot=newCharacter:WaitForChild("HumanoidRootPart",5)
				if newRoot then newRoot.CFrame=savedCFrame workspace.CurrentCamera.CFrame=savedCameraCFrame end
				if callback then task.defer(callback,newCharacter) end
				isRefreshing=false
			end)
		end
		return RefreshCharacter
	end

	local function AutoUnEquip()
		if firsttime then
			local tool=Player.Character and Player.Character:FindFirstChildOfClass("Tool")
			if tool then tool.Parent=Player.Backpack end
			firsttime=false
		end
	end

	local function TurnInvisible()
		if not invisActive then return end
		QuickRespawn()
		local currentglove=Player:WaitForChild("leaderstats").Glove.Value
		local gloveObj=workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild(currentglove)
		local glovecd=gloveObj and gloveObj:FindFirstChild("ClickDetector")
		local ghostObj=workspace:FindFirstChild("Lobby") and workspace.Lobby:FindFirstChild("Ghost")
		local ghostcd=ghostObj and ghostObj:FindFirstChild("ClickDetector")
		if not glovecd or not ghostcd then return end
		fireclickdetector(ghostcd)
		event:FireServer()
		fireclickdetector(glovecd)
	end

	TurnInvisible()

	local charConn=Player.CharacterAdded:Connect(function()
		if not invisActive then return end
		firsttime=true
		task.wait(0.5)
		TurnInvisible()
	end)
	invisCharConn=charConn

	-- Setup tool auto-unequip on current char
	local function setupToolConn(char)
		if invisToolConn then invisToolConn:Disconnect() end
		invisToolConn=char.ChildAdded:Connect(function(child)
			if not invisActive then return end
			if child:IsA("Tool") then task.wait(0.01) AutoUnEquip() end
		end)
	end

	if Player.Character then setupToolConn(Player.Character) end
	Player.CharacterAdded:Connect(function(newChar)
		if not invisActive then return end
		setupToolConn(newChar)
	end)
end

