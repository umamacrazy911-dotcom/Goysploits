local function runIcyTrials()
	if game.PlaceId~=17290438723 then
		showToast("Teleporting to Icy Trials...",Color3.fromRGB(200,180,80))
		task.spawn(function()
			local ok,err=pcall(function() TeleportService:Teleport(17290438723,Player) end)
			if not ok then showToast("TP Failed: "..tostring(err):sub(1,30),Color3.fromRGB(200,80,80)) end
		end)
		return
	end
	task.spawn(function()
		local ok,err=pcall(function()
			workspace.FinishDoor_Ice.Model.Part.ProximityPrompt.HoldDuration=0
			local deadline=tick()+5
			while tick()<deadline do
				task.wait(0.1)
				if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then break end
				safeTeleportCFrame(CFrame.new(Vector3.new(-557.204833984375,177.94590759277344,54.048336029052734)))
				fireproximityprompt(workspace.FinishDoor_Ice.Model.Part.ProximityPrompt)
			end
		end)
		if not ok then showToast("Icy Trials: "..tostring(err):sub(1,40),Color3.fromRGB(200,80,80)) end
	end)
end
createScriptButton({key="IcyTrials",label="Icy Trials",runOnce=true,runScript=runIcyTrials},ObtainmentGrid)

local function runAutoPsycho()
	task.spawn(function()
		local ok,err=pcall(function()
			local MapExists=workspace.RepressedMemoriesMap
			if not MapExists then showToast("RepressedMemoriesMap not found",Color3.fromRGB(200,80,80)) return end
			local PsychoStart=MapExists.Psychokinesis.Triggers.StartPsychoEvent
			local PsychoStop=MapExists.Psychokinesis.Triggers.StopPsychoEvent
			local PsychoCollect=MapExists.Psychokinesis.Triggers.Psycho.ClickDetector
			local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
			firetouchinterest(hrp,PsychoStart,0) firetouchinterest(hrp,PsychoStart,1)
			task.wait(6)
			hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
			firetouchinterest(hrp,PsychoStop,0) firetouchinterest(hrp,PsychoStop,1)
			task.wait(0.5)
			fireclickdetector(PsychoCollect)
		end)
		if not ok then showToast("AutoPsycho: "..tostring(err):sub(1,40),Color3.fromRGB(200,80,80)) end
	end)
end
