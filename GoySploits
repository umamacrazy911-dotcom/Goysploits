local invis={active=false,conns={}}
local function stopInvisibility()
	invis.active=false for _,c in ipairs(invis.conns) do pcall(function() c:Disconnect() end) end invis.conns={}
end
local function startInvisibility()
	local ls=Player:FindFirstChild("leaderstats") local sl=ls and ls:FindFirstChild("Slaps") local sc=sl and sl.Value or 0
	if sc<666 then showToast("Need 666 slaps! You have "..sc,T.RED) states.Invisibility=false if tileRefs.Invisibility then tileRefs.Invisibility(false) end return end
	invis.active=true
	local event=game.ReplicatedStorage:WaitForChild("Ghostinvisibilityactivated",5)
	local event1=game.ReplicatedStorage:WaitForChild("Ghostinvisibilitydeactivated",5)
	if not event or not event1 then showToast("Ghost events not found",T.RED) stopInvisibility() states.Invisibility=false if tileRefs.Invisibility then tileRefs.Invisibility(false) end return end
	local plr=Player local firsttime=true
	local currentglove=plr:WaitForChild("leaderstats").Glove.Value
	local glovecd=workspace.Lobby:FindFirstChild(currentglove) and workspace.Lobby:FindFirstChild(currentglove):FindFirstChildOfClass("ClickDetector")
	local ghostcd=workspace.Lobby.Ghost.ClickDetector
	local function QuickRespawn()
		local isRef=false
		local function RefreshCharacter(cb)
			if isRef then return end isRef=true
			local character=plr.Character if not character then isRef=false return end
			local rootPart=character:FindFirstChild("HumanoidRootPart")
			local savedCF=rootPart and rootPart.CFrame or CFrame.new(0,5,0) local savedCamCF=workspace.CurrentCamera.CFrame
			task.spawn(function()
				local hum=character:FindFirstChildWhichIsA("Humanoid") if hum then hum:ChangeState(Enum.HumanoidStateType.Dead) end
				character:ClearAllChildren()
				local tmp=Instance.new("Model") tmp.Name="TempRefreshModel" tmp.Parent=workspace
				plr.Character=tmp task.wait() plr.Character=character tmp:Destroy()
				local newChar=plr.CharacterAdded:Wait()
				local newRoot=newChar:WaitForChild("HumanoidRootPart",5)
				if newRoot then newRoot.CFrame=savedCF workspace.CurrentCamera.CFrame=savedCamCF end
				if cb then task.defer(cb,newChar) end isRef=false
			end)
		end
		return RefreshCharacter
	end
	local function TurnInvisible()
		if not invis.active then return end QuickRespawn()
		currentglove=plr:WaitForChild("leaderstats").Glove.Value
		local gm=workspace.Lobby:FindFirstChild(currentglove)
		if gm then local cd=gm:FindFirstChildOfClass("ClickDetector") if not cd then for _,d in pairs(gm:GetDescendants()) do if d:IsA("ClickDetector") then cd=d break end end end if cd then glovecd=cd end end
		if not invis.active then return end fireclickdetector(ghostcd) event:FireServer() if glovecd then fireclickdetector(glovecd) end
	end
	local function AutoUnEquip() if not invis.active then return end if firsttime then local t=plr.Character and plr.Character:FindFirstChildOfClass("Tool") if t then t.Parent=plr.Backpack end firsttime=false end end
	local charConn=plr.CharacterAdded:Connect(function(newChar)
		if not invis.active then return end firsttime=true task.wait(0.5) if not invis.active then return end TurnInvisible()
		local c2=newChar.ChildAdded:Connect(function(child) if not invis.active then return end if child:IsA("Tool") then task.wait(0.01) AutoUnEquip() end end) table.insert(invis.conns,c2)
	end)
	table.insert(invis.conns,charConn)
	local char=plr.Character if char then local c3=char.ChildAdded:Connect(function(child) if not invis.active then return end if child:IsA("Tool") then task.wait(0.01) AutoUnEquip() end end) table.insert(invis.conns,c3) end
	TurnInvisible()
end

