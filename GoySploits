			local PsychoStart=MapExists.Psychokinesis.Triggers.StartPsychoEvent
			local PsychoStop=MapExists.Psychokinesis.Triggers.StopPsychoEvent
			local PsychoCollect=MapExists.Psychokinesis.Triggers.Psycho.ClickDetector
			local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
			firetouchinterest(hrp,PsychoStart,0) firetouchinterest(hrp,PsychoStart,1)
			task.wait(6)
			hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
			firetouchinterest(hrp,PsychoStop,0) firetouchinterest(hrp,PsychoStop,1)
			task.wait(0.5)
