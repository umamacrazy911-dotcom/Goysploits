	if sfListMode=="Whitelist" then if not sfSelectedPlayers[p.Name] then return false end
	elseif sfListMode=="Blacklist" then if sfSelectedPlayers[p.Name] then return false end end
	if sfIgnoreVoid and pHRP.Position.Y<-15 then return false end
	if sfIgnoreRock and sfHasRockGlove(p) then return false end
	if sfIgnoreLongDistance and hrp then if (pHRP.Position-hrp.Position).Magnitude>1500 then return false end end
