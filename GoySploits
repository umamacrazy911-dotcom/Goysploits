-- =====================
local reachConnections={} local reachHRPConnections={}
local reachCurrentTool=nil local reachCurrentPart=nil local reachPart=nil local reachBox=nil
local lengthVar=10 local widthVar=10 local hitFloor=false
local GLOVE_DEFAULT_SIZE=Vector3.new(2.469702959060669,2.844676971435547,1.1790461540222168)
local function getReachXWidth() return hitFloor and 5.25 or 1 end
local function hideReachPart() if reachPart then reachPart.Anchored=true reachPart.CFrame=CFrame.new(0,-9999,0) end end
local function applyToTool(tool)
	task.wait() reachCurrentTool=tool reachCurrentPart=nil
	local xw=getReachXWidth()
	for _,part in pairs(tool:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Size=Vector3.new(xw,lengthVar,widthVar) part.Transparency=1 part.CanCollide=false
			if not reachCurrentPart then reachCurrentPart=part end
		end
	end
	if reachCurrentPart and reachPart then
		reachPart.Anchored=false reachPart.Size=Vector3.new(xw,lengthVar,widthVar) reachPart.CFrame=reachCurrentPart.CFrame
		local ow=reachPart:FindFirstChild("ReachWeld") if ow then ow:Destroy() end
		local weld=Instance.new("WeldConstraint") weld.Name="ReachWeld" weld.Part0=reachPart weld.Part1=reachCurrentPart weld.Parent=reachPart
	end
end
local function refreshSize()
	if not reachCurrentTool or not reachCurrentTool.Parent then return end
	local xw=getReachXWidth()
	for _,part in pairs(reachCurrentTool:GetDescendants()) do if part:IsA("BasePart") then part.Size=Vector3.new(xw,lengthVar,widthVar) end end
	if reachPart then reachPart.Size=Vector3.new(xw,lengthVar,widthVar) end
end
local function revertToolParts()
	if reachCurrentTool and reachCurrentTool.Parent then
		for _,part in pairs(reachCurrentTool:GetChildren()) do
			if part.Name=="Glove" then part.Size=GLOVE_DEFAULT_SIZE part.Transparency=0 end
		end
	end
end
local function stopReach()
	revertToolParts()
	for _,c in pairs(reachConnections) do c:Disconnect() end reachConnections={}
	for _,c in pairs(reachHRPConnections) do c:Disconnect() end reachHRPConnections={}
	if reachPart then local w=reachPart:FindFirstChild("ReachWeld") if w then w:Destroy() end reachPart:Destroy() reachPart=nil end
	if reachBox then reachBox:Destroy() reachBox=nil end
	reachCurrentTool=nil reachCurrentPart=nil
	for _,p in pairs(game.Players:GetPlayers()) do
		if p~=Player and p.Character then local hrp=p.Character:FindFirstChild("HumanoidRootPart") if hrp then hrp.Size=Vector3.new(2,2,1) hrp.Transparency=1 hrp.CanCollide=false end end
	end
end
local function startReach()
	reachPart=Instance.new("Part") reachPart.Name="ReachPart" reachPart.Anchored=true reachPart.CanCollide=false
	reachPart.Transparency=1 reachPart.Massless=true reachPart.Size=Vector3.new(getReachXWidth(),widthVar,lengthVar)
	reachPart.CFrame=CFrame.new(0,-9999,0) reachPart.Parent=workspace
	reachBox=Instance.new("SelectionBox") reachBox.Adornee=reachPart reachBox.Color3=THEME.GLOW_WHITE
	reachBox.LineThickness=0.05 reachBox.SurfaceTransparency=0.6 reachBox.SurfaceColor3=THEME.GLOW_WHITE reachBox.Parent=workspace
	local function onToolRemoved(child)
		if child:IsA("Tool") then reachCurrentTool=nil reachCurrentPart=nil local ow=reachPart and reachPart:FindFirstChild("ReachWeld") if ow then ow:Destroy() end hideReachPart() end
	end
	local function onToolEquipped(child) if child:IsA("Tool") then applyToTool(child) end end
	table.insert(reachConnections,Player.CharacterAdded:Connect(function(char) task.wait() table.insert(reachConnections,char.ChildAdded:Connect(onToolEquipped)) table.insert(reachConnections,char.ChildRemoved:Connect(onToolRemoved)) end))
	if Player.Character then
		table.insert(reachConnections,Player.Character.ChildAdded:Connect(onToolEquipped))
		table.insert(reachConnections,Player.Character.ChildRemoved:Connect(onToolRemoved))
		for _,child in pairs(Player.Character:GetChildren()) do if child:IsA("Tool") then applyToTool(child) end end
	end
end
