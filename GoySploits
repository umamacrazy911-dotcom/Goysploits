local function startAutoPoltergeist()
	-- If not in the right place, TP there instead
	if game.PlaceId ~= 103505724406848 then
		showToast("Teleporting to Poltergeist map...", Color3.fromRGB(200,180,80))
		task.spawn(function()
			local ok,err=pcall(function() TeleportService:Teleport(103505724406848, Player) end)
			if not ok then showToast("TP Failed: "..tostring(err):sub(1,30), Color3.fromRGB(200,80,80)) end
		end)
		-- flip the toggle back off since we're leaving
		states["AutoPoltergeist"]=false
		if tileRefs["AutoPoltergeist"] then tileRefs["AutoPoltergeist"](false) end
		return
	end

	poltergeistActive=true

	task.spawn(function()
		local ok,err=pcall(function()
			-- Equip glove
			local char=Player.Character
			local hum=char and char:FindFirstChild("Humanoid")
			local glove=char and char:FindFirstChildOfClass("Tool") and char:FindFirstChildOfClass("Tool"):FindFirstChild("Glove")
			if not glove then
				local bt=Player.Backpack:FindFirstChildOfClass("Tool")
				if bt and hum then hum:EquipTool(bt) task.wait(0.2) end
				local t2=char:FindFirstChildOfClass("Tool")
				glove=t2 and t2:FindFirstChild("Glove")
			end
			if not glove then showToast("No glove equipped",Color3.fromRGB(200,80,80)) poltergeistActive=false return end

			-- Create floor part
			poltergeistSlotPart=Instance.new("Part")
			poltergeistSlotPart.Parent=workspace poltergeistSlotPart.Anchored=true poltergeistSlotPart.CanCollide=true
			poltergeistSlotPart.Size=Vector3.new(10,1,10) poltergeistSlotPart.Transparency=1
			poltergeistSlotPart.Position=Vector3.new(-21,0,-125.5)

			glove.Size=Vector3.new(20,20,20)

			local tool=glove.Parent

			-- Safety heartbeat: lock character in place
			poltergeistSafetyConn=RunService.Heartbeat:Connect(function()
				if not poltergeistActive then return end
				local c=Player.Character if not c then return end
				local h=c:FindFirstChild("HumanoidRootPart") if not h then return end
				h.CFrame=CFrame.new(-21,3,-125.5)*CFrame.Angles(0,math.rad(-99),0)
			end)

			-- Main attack loop
			while poltergeistActive do
				-- Re-grab tool in case it changed
				local currentChar=Player.Character
				tool=currentChar and currentChar:FindFirstChildOfClass("Tool")
				if not tool then
					local bp=Player.Backpack:FindFirstChildOfClass("Tool")
					if bp and currentChar and currentChar:FindFirstChild("Humanoid") then
						currentChar.Humanoid:EquipTool(bp) task.wait(0.2)
						tool=currentChar:FindFirstChildOfClass("Tool")
					end
				end
				if tool then
					tool:Activate()
					task.wait(0.05)
					local newTool=tool:Clone()
					tool:Destroy()
					newTool.Parent=Player.Backpack
					task.wait()
					local c2=Player.Character
					if c2 and c2:FindFirstChild("Humanoid") then
						c2.Humanoid:EquipTool(newTool)
						tool=newTool
						local ng=tool:FindFirstChild("Glove")
						if ng then ng.Size=Vector3.new(20,20,20) end
					end
				end
				task.wait(0.07)
			end
		end)
		if not ok then showToast("Poltergeist: "..tostring(err):sub(1,40),Color3.fromRGB(200,80,80)) end
		stopAutoPoltergeist()
	end)
end

