local esp={active=false,color=Color3.fromRGB(255,255,255),data={},listMode="Blacklist",selPlayers={},conns={}}
local function espPassFilter(p) if esp.listMode=="Whitelist" then return esp.selPlayers[p.Name]==true else return not esp.selPlayers[p.Name] end end
local function espRemove(p)
	if esp.data[p] then
		if esp.data[p].hl then pcall(function() esp.data[p].hl:Destroy() end) end
		if esp.data[p].box then pcall(function() esp.data[p].box:Destroy() end) end
		esp.data[p]=nil
	end
end
local function espAdd(p)
	espRemove(p)
	local char=p.Character if not char then return end
	local hrp=char:FindFirstChild("HumanoidRootPart")
	local hl=Instance.new("Highlight")
	hl.Adornee=char hl.FillTransparency=1 hl.OutlineColor=esp.color hl.OutlineTransparency=0
	hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop hl.Parent=CoreGui
	local box=nil
	if hrp then
		box=Instance.new("Part")
		box.Name="ESPBox" box.Anchored=true box.CanCollide=false box.CastShadow=false
		box.Size=Vector3.new(4,6,4) box.Transparency=0.9
		box.Color=esp.color box.Material=Enum.Material.Neon
		box.Parent=workspace
	end
	esp.data[p]={hl=hl,box=box,char=char}
end
local function espRefresh()
	for p,_ in pairs(esp.data) do
		if not game.Players:FindFirstChild(p.Name) or not espPassFilter(p) then espRemove(p) end
	end
	for _,p in pairs(game.Players:GetPlayers()) do
		if p==Player then continue end
		if not espPassFilter(p) then espRemove(p) continue end
		local char=p.Character
		if char then
			local d=esp.data[p]
			if not d or not d.hl or not d.hl.Parent then espAdd(p)
			elseif d.char~=char then espAdd(p) end
		else espRemove(p) end
	end
end
local function espUpdateColors()
	for _,d in pairs(esp.data) do
		if d.hl and d.hl.Parent then d.hl.OutlineColor=esp.color end
		if d.box and d.box.Parent then d.box.Color=esp.color end
	end
end
local function stopPlayerESP()
	esp.active=false
	for _,c in pairs(esp.conns) do c:Disconnect() end esp.conns={}
	for p,_ in pairs(esp.data) do espRemove(p) end esp.data={}
end
local function startPlayerESP()
	esp.active=true espRefresh()
	table.insert(esp.conns,RunService.Heartbeat:Connect(function()
		if not esp.active then return end
		espRefresh()
		for _,d in pairs(esp.data) do
			if d.box and d.box.Parent and d.char then
				local hrp=d.char:FindFirstChild("HumanoidRootPart")
				if hrp then d.box.CFrame=hrp.CFrame end
			end
		end
	end))
	table.insert(esp.conns,game.Players.PlayerAdded:Connect(function(p) p.CharacterAdded:Connect(function() task.wait(0.5) if esp.active and espPassFilter(p) then espAdd(p) end end) end))
	table.insert(esp.conns,game.Players.PlayerRemoving:Connect(function(p) espRemove(p) end))
	for _,p in pairs(game.Players:GetPlayers()) do if p~=Player then p.CharacterAdded:Connect(function() task.wait(0.5) if esp.active and espPassFilter(p) then espAdd(p) end end) end end
end
