local function safeTeleportCFrame(cf)
	local char = Player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local relCFrames = {}
	local hrpCF = hrp.CFrame
	for _, part in pairs(char:GetDescendants()) do
		if part:IsA("BasePart") and part ~= hrp then
			relCFrames[part] = hrpCF:ToObjectSpace(part.CFrame)
		end
	end
	hrp.CFrame = cf
	local newHRPCF = hrp.CFrame
	for part, rel in pairs(relCFrames) do
		if part and part.Parent then
			part.CFrame = newHRPCF:ToWorldSpace(rel)
		end
	end
end

local function makeDraggable(frame, handle)
	handle = handle or frame
	local dragging, dragInput, dragStart, startPos
	handle.InputBegan:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
			dragging=true dragStart=input.Position startPos=frame.Position
			input.Changed:Connect(function() if input.UserInputState==Enum.UserInputState.End then dragging=false end end)
		end
	end)
	handle.InputChanged:Connect(function(input)
		if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then dragInput=input end
	end)
	RunService.RenderStepped:Connect(function()
		if dragging and dragInput then
			local delta=dragInput.Position-dragStart
			frame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
		end
	end)
end

local function addMinimizeButton(frame, titleBar, contentItems, titleBarPixelHeight)
	titleBarPixelHeight = titleBarPixelHeight or 28
	local minBtn=Instance.new("TextButton")
	minBtn.Size=UDim2.new(0,18,0,18) minBtn.Position=UDim2.new(1,-3,0,5) minBtn.AnchorPoint=Vector2.new(1,0)
	minBtn.BackgroundColor3=Color3.fromRGB(60,60,65) minBtn.Text="−" minBtn.TextColor3=Color3.fromRGB(200,200,200)
	minBtn.TextScaled=true minBtn.Font=Enum.Font.GothamBold minBtn.ZIndex=(frame.ZIndex or 10)+5 minBtn.Parent=frame
	local mbc=Instance.new("UICorner") mbc.CornerRadius=UDim.new(0.3,0) mbc.Parent=minBtn
	local minimized=false local originalSize=frame.Size
	minBtn.MouseButton1Click:Connect(function()
		minimized=not minimized
		if minimized then
			minBtn.Text="+" frame.Size=UDim2.new(originalSize.X.Scale,originalSize.X.Offset,0,titleBarPixelHeight)
			for _,c in ipairs(contentItems) do if c and c~=titleBar and c~=minBtn and c.Parent==frame then c.Visible=false end end
		else
			minBtn.Text="−" frame.Size=originalSize
			for _,c in ipairs(contentItems) do if c and c.Parent==frame then c.Visible=true end end
		end
	end)
	return minBtn
end

