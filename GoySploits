local sfSteppedConnection = nil
local sfWalkMoveConn = nil
local sfWalkIsMoving = false
local sfWalkAnimTrack = nil
local sfArmHoldConn = nil

local SPAWN_CFRAME = CFrame.new(-1210.16235,329.900879,3.98652339,1,0,0,0,1,0,0,0,1)
local SF_ROCK_GLOVES = {"Diamond","MEGAROCK","CUSTOM","Spectator"}
local SF_WALK_ANIM = "rbxassetid://913376220"

local function sfGetCharacter() return Player.Character end
local function sfGetHRP() 
    local char = sfGetCharacter()
    return char and char:FindFirstChild("HumanoidRootPart") 
end
local function sfHasTool() 
    local char = sfGetCharacter()
    return (char and char:FindFirstChildOfClass("Tool")) or Player.Backpack:FindFirstChildOfClass("Tool") 
end

local function sfEnableFlight(char)
    local root = char:FindFirstChild("HumanoidRootPart") if not root then return end
    local hum = char:FindFirstChild("Humanoid") if hum then hum.PlatformStand = true end
    if root:FindFirstChild("SFFlightGyro") then root:FindFirstChild("SFFlightGyro"):Destroy() end
    if root:FindFirstChild("SFFlightVelocity") then root:FindFirstChild("SFFlightVelocity"):Destroy() end
    local gyro = Instance.new("BodyGyro") gyro.Name="SFFlightGyro" gyro.D=400 gyro.P=1e6 gyro.MaxTorque=Vector3.new(1e6,1e6,1e6) gyro.CFrame=root.CFrame gyro.Parent=root
    local vel = Instance.new("BodyVelocity") vel.Name="SFFlightVelocity" vel.Velocity=Vector3.new(0,0,0) vel.MaxForce=Vector3.new(1e6,1e6,1e6) vel.Parent=root
end

local function sfDisableFlight(char)
    local root = char and char:FindFirstChild("HumanoidRootPart") if not root then return end
    local hum = char:FindFirstChild("Humanoid") if hum then hum.PlatformStand = false end
    if root:FindFirstChild("SFFlightGyro") then root:FindFirstChild("SFFlightGyro"):Destroy() end
    if root:FindFirstChild("SFFlightVelocity") then root:FindFirstChild("SFFlightVelocity"):Destroy() end
end

local function sfHasRockGlove(p)
    local ls = p:FindFirstChild("leaderstats")
    if not ls then return false end
    local glove = ls:FindFirstChild("Glove")
    if not glove then return false end
    for _, rg in pairs(SF_ROCK_GLOVES) do
        if glove.Value == rg then return true end
    end
    return false
end

local function sfPassesFilters(p)
    if not p.Character then return false end
    local pHRP = p.Character:FindFirstChild("HumanoidRootPart")
    if not pHRP then return false end

    if sf.ListMode == "Whitelist" and not sf.SelectedPlayers[p.Name] then return false end
    if sf.ListMode == "Blacklist" and sf.SelectedPlayers[p.Name] then return false end

    if sf.IgnoreVoid and pHRP.Position.Y < -15 then return false end
    if sf.IgnoreRock and sfHasRockGlove(p) then return false end

    local hrp = sfGetHRP()
    if sf.IgnoreLongDistance and hrp and (pHRP.Position - hrp.Position).Magnitude > 1500 then return false end
    if sf.IgnoreFriends and Player:IsFriendsWith(p.UserId) then return false end

    return true
end

local function sfGetTargets()
    local valid = {}
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= Player and p.Character and sfPassesFilters(p) then
            table.insert(valid, p)
        end
    end
    return valid
end

local function sfSlapFarm()
    local char = sfGetCharacter()
    local tool = char and char:FindFirstChildOfClass("Tool")
    if not tool then return end
    local clone = tool:Clone()
    tool:Destroy()
    clone.Parent = Player.Backpack
    task.wait()
    char.Humanoid:EquipTool(clone)
    task.wait()
    local newTool = char:FindFirstChildOfClass("Tool")
    if newTool then
        for _, part in pairs(newTool:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Size = Vector3.new(20,20,20)
                part.Transparency = 1
            end
        end
        newTool:Activate()
    end
end

local function sfStopWalkMovement()
    if sfWalkMoveConn then sfWalkMoveConn:Disconnect() sfWalkMoveConn = nil end
    sfWalkIsMoving = false
    if sfWalkAnimTrack then sfWalkAnimTrack:Stop() sfWalkAnimTrack = nil end
    if sfArmHoldConn then sfArmHoldConn:Disconnect() sfArmHoldConn = nil end
    local char = sfGetCharacter()
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid:MoveTo(char.HumanoidRootPart.Position)
    end
end

local function sfLoadWalkAnim()
    local char = sfGetCharacter()
    local hum = char and char:FindFirstChild("Humanoid")
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    if not animator then return end
    if sfWalkAnimTrack then return end
    local anim = Instance.new("Animation")
    anim.AnimationId = SF_WALK_ANIM
    sfWalkAnimTrack = animator:LoadAnimation(anim)
    sfWalkAnimTrack.Priority = Enum.AnimationPriority.Action
    sfWalkAnimTrack.Looped = true
    sfWalkAnimTrack:Play()
end

local function sfBeginWalkToTarget(p)
    sfStopWalkMovement()
    sfWalkIsMoving = true
    sfLoadWalkAnim()

    sfWalkMoveConn = RunService.Heartbeat:Connect(function()
        if not sfWalkIsMoving then return end
        local pHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        local hum = sfGetCharacter() and sfGetCharacter():FindFirstChild("Humanoid")
        if pHRP and hum then
            hum:MoveTo(pHRP.Position)
        end
    end)
end

local function startSlapFarm()
    sf.Active = true

    sf.FlightConnection = RunService.RenderStepped:Connect(function()
        if sf.WalkMode then return end
        local hrp = sfGetHRP()
        if not hrp or not sf.FlightEnabled then return end
        local vel = hrp:FindFirstChild("SFFlightVelocity")
        local gyro = hrp:FindFirstChild("SFFlightGyro")
        if not vel or not gyro then return end

        if sf.TargetToFollow and sf.TargetToFollow.Character then
            local tHRP = sf.TargetToFollow.Character:FindFirstChild("HumanoidRootPart")
            if tHRP then
                local diff = (tHRP.Position + Vector3.new(0,10,0)) - hrp.Position
                local dist = diff.Magnitude
                vel.Velocity = dist > 1 and (diff.Unit * math.min(dist*20, sf.FlightSpeed)) or Vector3.zero
                gyro.CFrame = CFrame.new(hrp.Position, tHRP.Position)
            end
        else
            vel.Velocity = Vector3.zero
            gyro.CFrame = CFrame.new(hrp.Position)
        end
    end)

    sf.SteppedConnection = RunService.Stepped:Connect(function()
        local char = sfGetCharacter()
        if char and sf.FlightEnabled and not sf.WalkMode then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end)

    task.spawn(function()
        while sf.Active do
            task.wait(0.1)
            local char = sfGetCharacter()
            local hrp = sfGetHRP()
            local hasTool = sfHasTool()

            if sf.WalkMode then
                -- Walk Mode Logic (same as before)
                if not hasTool then sfStopWalkMovement() if hrp then safeTeleportCFrame(SPAWN_CFRAME) end continue end
                -- ... (rest of your walk mode code stays functionally identical)
                local tool = char and char:FindFirstChildOfClass("Tool")
                if not tool then
                    local myTool = Player.Backpack:FindFirstChildOfClass("Tool")
                    if myTool and char and char:FindFirstChild("Humanoid") then
                        char.Humanoid:EquipTool(myTool)
                        task.wait(0.1)
                    end
                end
                local targets = sfGetTargets()
                if #targets == 0 then sfStopWalkMovement() continue end
                local p = targets[1]
                if not sfPassesFilters(p) then sfStopWalkMovement() continue end
                sf.LastTarget = p
                sf.TargetToFollow = p
                sfBeginWalkToTarget(p)
                -- timeout logic...
                local timeout = tick() + 5
                repeat
                    task.wait(0.05)
                    if not sf.Active or not sf.WalkMode then break end
                    local pHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
                    if not pHRP or not sfPassesFilters(p) then break end
                    if hrp and (pHRP.Position - hrp.Position).Magnitude < 6 then break end
                until tick() > timeout

                sfStopWalkMovement()
                tool = char and char:FindFirstChildOfClass("Tool")
                if tool then
                    tool:Activate()
                    task.wait(sf.AntiKick and 1 or 0.1)
                    sfSlapFarm()
                    task.wait(0.1)
                end
                sf.TargetToFollow = nil
            else
                -- Flight Mode Logic (same as before)
                sfStopWalkMovement()
                if not hasTool then
                    if sf.FlightEnabled then sf.FlightEnabled = false sf.TargetToFollow = nil sfDisableFlight(char) end
                    if hrp then safeTeleportCFrame(SPAWN_CFRAME) end
                    continue
                end
                if not sf.FlightEnabled then sf.FlightEnabled = true sfEnableFlight(char) end
                -- ... rest of flight mode remains the same
                local tool = char and char:FindFirstChildOfClass("Tool")
                if not tool then
                    local myTool = Player.Backpack:FindFirstChildOfClass("Tool")
                    if myTool and char and char:FindFirstChild("Humanoid") then
                        char.Humanoid:EquipTool(myTool)
                        task.wait(0.1)
                    end
                end
                local targets = sfGetTargets()
                if #targets == 0 then sf.TargetToFollow = nil continue end
                for _, p in pairs(targets) do
                    if not sfPassesFilters(p) then continue end
                    sf.LastTarget = p
                    sf.TargetToFollow = p
                    local followEnd = tick() + 2
                    while tick() < followEnd do
                        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then break end
                        if not sfPassesFilters(p) then sf.TargetToFollow = nil break end
                        tool = char and char:FindFirstChildOfClass("Tool")
                        if tool then
                            tool:Activate()
                            task.wait(1.5)
                            sfSlapFarm()
                            task.wait(0.1)
                        else
                            break
                        end
                    end
                    if sf.AntiKick then task.wait(1) end
                    sf.TargetToFollow = nil
                end
            end
        end
    end)
end

local function stopSlapFarm()
    sf.Active = false
    sf.FlightEnabled = false
    sf.TargetToFollow = nil
    sf.LastTarget = nil
    sfStopWalkMovement()

    if sf.FlightConnection then sf.FlightConnection:Disconnect() sf.FlightConnection = nil end
    if sf.SteppedConnection then sf.SteppedConnection:Disconnect() sf.SteppedConnection = nil end

    local char = sfGetCharacter()
    if char then sfDisableFlight(char) end
end
