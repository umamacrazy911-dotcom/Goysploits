local function sfGetTargets()
	local hrp=sfGetHRP() local valid={}
	for _,p in pairs(game.Players:GetPlayers()) do if p==Player then continue end if not p.Character then continue end if sfPassesFilters(p) then table.insert(valid,p) end end
	if sfTargetMode=="Nearest Player" and hrp and #valid>0 then
		local nearest,nearestDist=nil,math.huge
		for _,p in pairs(valid) do local pHRP=p.Character:FindFirstChild("HumanoidRootPart") if pHRP then local d=(pHRP.Position-hrp.Position).Magnitude if d<nearestDist then nearestDist=d nearest=p end end end
		return nearest and {nearest} or {}
	elseif sfTargetMode=="Nearest Alternate" and hrp and #valid>0 then
		table.sort(valid,function(a,b) local aH=a.Character:FindFirstChild("HumanoidRootPart") local bH=b.Character:FindFirstChild("HumanoidRootPart") if not aH then return false end if not bH then return true end return (aH.Position-hrp.Position).Magnitude<(bH.Position-hrp.Position).Magnitude end)
