local slappleActive=false local slappleConns={}
local function collectOneSlapple(slapple)
	if not slappleActive then return end
	local glove=slapple:FindFirstChild("Glove") if not glove then return end
	local part=glove:IsA("Model") and glove.PrimaryPart or glove
	local char=Player.Character
	if part and char and char:FindFirstChild("HumanoidRootPart") then
		firetouchinterest(char.HumanoidRootPart,part,0) task.wait(0.05)
		char=Player.Character
		if char and char:FindFirstChild("HumanoidRootPart") and part and part.Parent then firetouchinterest(char.HumanoidRootPart,part,1) end
	end
end
local function sweepAllSlapples()
	if not slappleActive then return end
	local arena=workspace:FindFirstChild("Arena") if not arena then return end
	for _,island in pairs(arena:GetChildren()) do
		local slapples=island:FindFirstChild("Slapples") if not slapples then continue end
		for _,slapple in pairs(slapples:GetChildren()) do
			if not slappleActive then return end collectOneSlapple(slapple) task.wait(0.05)
		end
	end
end
local function stopAutoSlapple()
	slappleActive=false
	for _,c in pairs(slappleConns) do pcall(function() c:Disconnect() end) end slappleConns={}
end
local function startAutoSlapple()
	stopAutoSlapple() slappleActive=true
	task.spawn(sweepAllSlapples)
	table.insert(slappleConns,workspace.DescendantAdded:Connect(function(obj)
		if not slappleActive then return end
		if obj.Name=="Glove" then local par=obj.Parent if par and par.Parent and par.Parent.Name=="Slapples" then task.wait(0.15) if slappleActive then collectOneSlapple(par) end end end
	end))
	task.spawn(function() while slappleActive do task.wait(0.8) if slappleActive then sweepAllSlapples() end end end)
	table.insert(slappleConns,Player.CharacterAdded:Connect(function()
		if not slappleActive then return end
		task.wait(1.5)
		if slappleActive then
			for _,c in pairs(slappleConns) do pcall(function() c:Disconnect() end) end slappleConns={}
			task.spawn(startAutoSlapple)
		end
	end))
end

