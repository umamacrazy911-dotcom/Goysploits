local krakenActive=false local krakenTween=nil local krakenConnection=nil
local function startAutoKraken()
	krakenActive=true
	krakenConnection=RunService.Heartbeat:Connect(function()
		if not krakenActive then return end
		local char=Player.Character if not char then return end
		local root=char:FindFirstChild("HumanoidRootPart") if not root then return end
		local hurtbox=workspace:FindFirstChild("kraken_hurtbox",true)
		if hurtbox and hurtbox:IsA("BasePart") then
			if krakenTween then krakenTween:Cancel() end
			local tweenInfo=TweenInfo.new(0.75,Enum.EasingStyle.Linear,Enum.EasingDirection.Out,0,false,0)
			krakenTween=TweenService:Create(root,tweenInfo,{CFrame=hurtbox.CFrame}) krakenTween:Play()
			local tool=char:FindFirstChildOfClass("Tool") if tool then mouse1click() end
		else
			if krakenTween then krakenTween:Cancel() krakenTween=nil end
			safeTeleportCFrame(CFrame.new(153,65,-12664))
		end
	end)
	Player.CharacterAdded:Connect(function() krakenTween=nil end)
