		elseif key=="TelAviv" then SL.Text="✈ TP'd!" tw(SL,{TextColor3=T.GRN}) tw(TS,{Color=T.GRN}) task.delay(2,function() SL.Text="Click to Go" tw(SL,{TextColor3=T.SDIM}) tw(TS,{Color=T.SDIM}) end)
		elseif runOnce then SL.Text="✓ Ran!" tw(SL,{TextColor3=T.GRN}) tw(TS,{Color=T.GRN}) task.delay(1.5,function() SL.Text="Click to Run" tw(SL,{TextColor3=T.SDIM}) tw(TS,{Color=T.SDIM}) end)
		else SL.Text=on and "ON" or "OFF" tw(SL,{TextColor3=on and T.GRN or T.SDIM}) tw(TS,{Color=on and T.STR or T.SDIM}) tw(Tile,{BackgroundColor3=on and Color3.fromRGB(18,20,18) or T.TILE}) end
	end
	if not runOnce and key~="TelAviv" then tileRefs[key]=setVisual end
	local function doAction()
		if key=="TelAviv" then doTelAvivTP() setVisual(true)
		elseif runOnce then if data.runScript then data.runScript() end setVisual(true)
		elseif oneShot then if not loaded then loaded=true setVisual(true) toggleFunctions[key](true) end
		else local ns=not states[key] states[key]=ns setVisual(ns) toggleFunctions[key](ns) end
	end
	CZ.MouseButton1Click:Connect(doAction)
	BL.MouseButton1Click:Connect(function()
		if bindingScript then return end bindingScript=key BL.Text="press a key..." tw(BL,{TextColor3=T.WHITE})
		local conn conn=UIS.InputBegan:Connect(function(input,gpe)
			if input.UserInputType==Enum.UserInputType.Keyboard then
				if input.KeyCode==binds[key] then task.wait() binds[key]=nil BL.Text="click to bind" tw(BL,{TextColor3=T.SDIM}) bindingScript=nil conn:Disconnect()
				else task.wait() binds[key]=input.KeyCode BL.Text=input.KeyCode.Name tw(BL,{TextColor3=T.DIM}) bindingScript=nil conn:Disconnect() end
			end
		end)
	end)
end

