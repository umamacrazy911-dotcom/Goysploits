-- Player ESP
-- =====================
local espActive=false
local espBoxes={}
local espConnections={}
local espListMode="Blacklist"
local espSelectedPlayers={}

local function removeESPForPlayer(p)
	if espBoxes[p.Name] then
		espBoxes[p.Name]:Destroy()
		espBoxes[p.Name]=nil
	end
end

local function addESPForPlayer(p)
	if p==Player then return end
	if espListMode=="Whitelist" and not espSelectedPlayers[p.Name] then return end
	if espListMode=="Blacklist" and espSelectedPlayers[p.Name] then return end
	if not p.Character then return end
	local hrp=p.Character:FindFirstChild("HumanoidRootPart") if not hrp then return end
	if espBoxes[p.Name] then espBoxes[p.Name]:Destroy() end
	local box=Instance.new("SelectionBox")
	box.Adornee=hrp
	box.Color3=Color3.fromRGB(0,200,255)
	box.LineThickness=0.06
	box.SurfaceTransparency=1
	box.SurfaceColor3=Color3.fromRGB(0,200,255)
	box.Parent=workspace
	espBoxes[p.Name]=box
end

local function refreshAllESP()
	for _,p in pairs(game.Players:GetPlayers()) do
		removeESPForPlayer(p)
		if espActive then addESPForPlayer(p) end
	end
end

local function startPlayerESP()
	espActive=true
	for _,p in pairs(game.Players:GetPlayers()) do addESPForPlayer(p) end
	table.insert(espConnections,game.Players.PlayerAdded:Connect(function(p)
		if not espActive then return end
		p.CharacterAdded:Connect(function() task.wait(0.5) addESPForPlayer(p) end)
	end))
	table.insert(espConnections,game.Players.PlayerRemoving:Connect(function(p) removeESPForPlayer(p) end))
	for _,p in pairs(game.Players:GetPlayers()) do
		if p~=Player then
			table.insert(espConnections,p.CharacterAdded:Connect(function()
				if not espActive then return end
				task.wait(0.5) addESPForPlayer(p)
			end))
		end
	end
end

local function stopPlayerESP()
	espActive=false
	for _,box in pairs(espBoxes) do if box and box.Parent then box:Destroy() end end
	espBoxes={}
	for _,c in ipairs(espConnections) do c:Disconnect() end espConnections={}
end

