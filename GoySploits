local function createScriptButton(data,grid)
	local key=data.key local label=data.label local oneShot=data.oneShot or false local runOnce=data.runOnce or false
	local Tile=Instance.new("Frame") Tile.BackgroundColor3=T.TILE Tile.ZIndex=10 Tile.Parent=grid addCorner(Tile,7)
	local TS=addStroke(Tile,T.SDIM,1)
	local NL=Instance.new("TextLabel") NL.Size=UDim2.new(1,0,0.45,0) NL.Position=UDim2.new(0,0,0.08,0) NL.BackgroundTransparency=1 NL.Text=label NL.TextColor3=T.WHITE NL.TextScaled=true NL.Font=Enum.Font.GothamBold NL.ZIndex=11 NL.Parent=Tile
	local SL=Instance.new("TextLabel") SL.Size=UDim2.new(1,0,0.2,0) SL.Position=UDim2.new(0,0,0.5,0) SL.BackgroundTransparency=1
	SL.Text=oneShot and "Click to Load" or (runOnce and "Click to Run" or (key=="TelAviv" and "Click to Go" or "OFF")) SL.TextColor3=T.SDIM SL.TextScaled=true SL.Font=Enum.Font.Gotham SL.ZIndex=11 SL.Parent=Tile
	local BL=Instance.new("TextButton") BL.Size=UDim2.new(0.85,0,0.22,0) BL.Position=UDim2.new(0.5,0,0.76,0) BL.AnchorPoint=Vector2.new(0.5,0) BL.BackgroundColor3=T.BG BL.Text="click to bind" BL.TextColor3=T.SDIM BL.TextScaled=true BL.Font=Enum.Font.Gotham BL.ZIndex=12 BL.Parent=Tile addCorner(BL,4) addStroke(BL,T.SDIM,1)
	local CZ=Instance.new("TextButton") CZ.Size=UDim2.new(1,0,0.75,0) CZ.Position=UDim2.new(0,0,0,0) CZ.BackgroundTransparency=1 CZ.Text="" CZ.ZIndex=13 CZ.Parent=Tile
	CZ.MouseEnter:Connect(function() tw(Tile,{BackgroundColor3=Color3.fromRGB(20,20,26)}) tw(TS,{Color=T.STR}) end)
	CZ.MouseLeave:Connect(function() if not states[key] then tw(Tile,{BackgroundColor3=T.TILE}) tw(TS,{Color=T.SDIM}) end end)
	if data.hoverWarning then
		local tip=Instance.new("Frame") tip.Size=UDim2.new(0,215,0,32) tip.AnchorPoint=Vector2.new(0.5,1) tip.BackgroundColor3=T.BG tip.BackgroundTransparency=0.08 tip.Visible=false tip.ZIndex=20 tip.Parent=ScreenGui addCorner(tip,6) addStroke(tip,T.SDIM,1)
		local tl=Instance.new("TextLabel") tl.Size=UDim2.new(1,0,1,0) tl.BackgroundTransparency=1 tl.Text=data.hoverWarning tl.TextColor3=T.DIM tl.TextScaled=true tl.Font=Enum.Font.GothamBold tl.ZIndex=21 tl.Parent=tip
		CZ.MouseEnter:Connect(function() tip.Visible=true local ap=Tile.AbsolutePosition local as=Tile.AbsoluteSize tip.Position=UDim2.fromOffset(ap.X+as.X/2,ap.Y-4) end)
		CZ.MouseLeave:Connect(function() tip.Visible=false end)
	end
	if panelConf[key] then
		local GB=Instance.new("TextButton") GB.Size=UDim2.new(0,20,0,20) GB.Position=UDim2.new(1,-2,0,2) GB.AnchorPoint=Vector2.new(1,0) GB.BackgroundColor3=T.MID GB.Text="⚙" GB.TextColor3=T.DIM GB.TextScaled=true GB.Font=Enum.Font.GothamBold GB.ZIndex=15 GB.Parent=Tile addCorner(GB,4) addStroke(GB,T.SDIM,1)
		GB.MouseButton1Click:Connect(function() settingsToggle(key) end)
	end
	if key=="TelAviv" then
		local HB=Instance.new("TextButton") HB.Size=UDim2.new(0,20,0,20) HB.Position=UDim2.new(1,-2,0,2) HB.AnchorPoint=Vector2.new(1,0) HB.BackgroundColor3=T.MID HB.Text="⌂" HB.TextColor3=T.WHITE HB.TextScaled=true HB.Font=Enum.Font.GothamBold HB.ZIndex=15 HB.Parent=Tile addCorner(HB,4) addStroke(HB,T.SDIM,1)
		HB.MouseButton1Click:Connect(function() doTelAvivHomeTP() end)
	end
	local loaded=false
	local function setVisual(on)
		if oneShot then SL.Text="Loaded" tw(SL,{TextColor3=T.GRN}) tw(TS,{Color=T.GRN})
		elseif key=="TelAviv" then SL.Text="✈ TP'd!" tw(SL,{TextColor3=T.GRN}) tw(TS,{Color=T.GRN}) task.delay(2,function() SL.Text="Click to Go" tw(SL,{TextColor3=T.SDIM}) tw(TS,{Color=T.SDIM}) end)
		elseif runOnce then SL.Text="✓ Ran!" tw(SL,{TextColor3=T.GRN}) tw(TS,{Color=T.GRN}) task.delay(1.5,function() SL.Text="Click to Run" tw(SL,{TextColor3=T.SDIM}) tw(TS,{Color=T.SDIM}) end)
		else SL.Text=on and "ON" or "OFF" tw(SL,{TextColor3=on and T.GRN or T.SDIM}) tw(TS,{Color=on and T.STR or T.SDIM}) tw(Tile,{BackgroundColor3=on and Color3.fromRGB(18,20,18) or T.TILE}) end
	end
	if not runOnce and key~="TelAviv" then tileRefs[key]=setVisual end
	local function doAction()
		if key=="TelAviv" then doTelAvivTP() setVisual(true)
		elseif runOnce then if data.runScript then data.runScript() end setVisual(true)
		elseif oneShot then if not loaded then loaded=true setVisual(true) toggleFunctions[key](true) end
		else local ns=not states[key] states[key]=ns setVisual(ns) toggleFunctions[key](ns) end
	end
	CZ.MouseButton1Click:Connect(doAction)
	BL.MouseButton1Click:Connect(function()
		if bindingScript then return end bindingScript=key BL.Text="press a key..." tw(BL,{TextColor3=T.WHITE})
		local conn conn=UIS.InputBegan:Connect(function(input,gpe)
			if input.UserInputType==Enum.UserInputType.Keyboard then
				if input.KeyCode==binds[key] then task.wait() binds[key]=nil BL.Text="click to bind" tw(BL,{TextColor3=T.SDIM}) bindingScript=nil conn:Disconnect()
				else task.wait() binds[key]=input.KeyCode BL.Text=input.KeyCode.Name tw(BL,{TextColor3=T.DIM}) bindingScript=nil conn:Disconnect() end
			end
		end)
	end)
end

