				repeat
					task.wait(0.05) if not slapFarmActive or not sfWalkMode then break end
					local pHRP2=p.Character and p.Character:FindFirstChild("HumanoidRootPart")
					if not pHRP2 or not sfPassesFilters(p) then break end
					if hrp and (pHRP2.Position-hrp.Position).Magnitude<6 then break end
				until tick()>timeout
				if sfWalkMoveConn then sfWalkMoveConn:Disconnect() sfWalkMoveConn=nil end sfWalkIsMoving=false
				tool=char and char:FindFirstChildOfClass("Tool")
				if tool then tool:Activate() if sfAntiKick then task.wait(1) else task.wait(0.1) end sfSlapFarm() task.wait(0.1) end
				sfTargetToFollow=nil
			else
				sfStopWalkMovement()
				if not toolExists then
					if sfFlightEnabled then sfFlightEnabled=false sfTargetToFollow=nil sfDisableFlight(char) end
					if hrp then safeTeleportCFrame(SPAWN_CFRAME) end continue
				end
				if not sfFlightEnabled then sfFlightEnabled=true sfEnableFlight(char) end
				local tool=char and char:FindFirstChildOfClass("Tool") local myTool=tool or Player.Backpack:FindFirstChildOfClass("Tool")
				if not tool and myTool then char.Humanoid:EquipTool(myTool) task.wait(0.1) end
				local targets=sfGetTargets() if #targets==0 then sfTargetToFollow=nil continue end
				for _,p in pairs(targets) do
					if not sfPassesFilters(p) then continue end
					sfTargetToFollow=p sfLastTarget=p local followEnd=tick()+2
					while tick()<followEnd do
						if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then break end
						if not sfPassesFilters(p) then sfTargetToFollow=nil break end
						tool=char and char:FindFirstChildOfClass("Tool")
						if tool then tool:Activate() task.wait(1.5) sfSlapFarm() task.wait(0.1) else break end
					end
					if sfAntiKick then task.wait(1) end
				end
				sfTargetToFollow=nil
			end
		end
	end)
end
local function stopSlapFarm()
	slapFarmActive=false sfFlightEnabled=false sfTargetToFollow=nil sfLastTarget=nil sfStopWalkMovement()
	if sfFlightConnection then sfFlightConnection:Disconnect() sfFlightConnection=nil end
	if sfSteppedConnection then sfSteppedConnection:Disconnect() sfSteppedConnection=nil end
	local char=sfGetCharacter()
	if char then sfDisableFlight(char) if char:FindFirstChild("Humanoid") then char.Humanoid:MoveTo(char.HumanoidRootPart and char.HumanoidRootPart.Position or Vector3.new(0,0,0)) end end
	sfSpeedSliderRef=nil sfSpeedBoxRef=nil sfSpeedKnobRef=nil
end
