local function runPocketDimension()
	task.spawn(function()
		local ok,err=pcall(function()
			local char=Player.Character if not char or not char:FindFirstChild("HumanoidRootPart") then return end
			local Redacted=workspace.PocketDimension.Doors
			for _,door in pairs(Redacted:GetChildren()) do
				firetouchinterest(char.HumanoidRootPart,door,0) firetouchinterest(char.HumanoidRootPart,door,1)
				task.wait(0.75) char=Player.Character
				if char and char:FindFirstChild("Humanoid") then
					if char.Humanoid.Health<=0 then task.wait(5.5) char=Player.Character else break end
				end
			end
		end)
		if not ok then showToast("PocketDim: "..tostring(err):sub(1,40),Color3.fromRGB(200,80,80)) end
	end)
end
createScriptButton({key="PocketDimension",label="Pocket Dim",runOnce=true,runScript=runPocketDimension},ObtainmentGrid)

local function runEasterEggs()
	local Eggs=workspace:FindFirstChild("EasterHuntEggs")
	if Eggs then
		for _,glove in pairs(Eggs:GetChildren()) do
			if glove then
				local part=glove:IsA("Model") and glove.PrimaryPart or glove
				if part and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
					firetouchinterest(Player.Character.HumanoidRootPart,part,0)
					firetouchinterest(Player.Character.HumanoidRootPart,part,1)
				end
			end
		end
	end
end
