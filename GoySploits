local reach={conns={},hrpConns={},tool=nil,part=nil,rPart=nil,rBox=nil,len=10,wid=10,floor=false}
local GLOVE_DEF=Vector3.new(2.469702959060669,2.844676971435547,1.1790461540222168)
local function getXW() return reach.floor and 5.25 or 1 end
local function hideRP() if reach.rPart then reach.rPart.Anchored=true reach.rPart.CFrame=CFrame.new(0,-9999,0) end end
local function attachReachPart()
	if not reach.rPart or not reach.part or not reach.part.Parent then return end
	local ow=reach.rPart:FindFirstChild("ReachWeld") if ow then ow:Destroy() end
	reach.rPart.Anchored=false reach.rPart.Size=Vector3.new(getXW(),reach.len,reach.wid) reach.rPart.CFrame=reach.part.CFrame
	local weld=Instance.new("WeldConstraint") weld.Name="ReachWeld" weld.Part0=reach.rPart weld.Part1=reach.part weld.Parent=reach.rPart
end
local function applyToTool(tool)
	task.wait() reach.tool=tool reach.part=nil local xw=getXW()
	for _,p in pairs(tool:GetDescendants()) do if p:IsA("BasePart") then p.Size=Vector3.new(xw,reach.len,reach.wid) p.Transparency=1 p.CanCollide=false if not reach.part then reach.part=p end end end
	attachReachPart()
end
local function refreshReachSize()
	if not reach.tool or not reach.tool.Parent then return end local xw=getXW()
	for _,p in pairs(reach.tool:GetDescendants()) do if p:IsA("BasePart") then p.Size=Vector3.new(xw,reach.len,reach.wid) end end
	if reach.rPart then reach.rPart.Size=Vector3.new(xw,reach.len,reach.wid) end
end
local function stopReach()
	if reach.tool and reach.tool.Parent then for _,p in pairs(reach.tool:GetChildren()) do if p.Name=="Glove" then p.Size=GLOVE_DEF p.Transparency=0 end end end
	for _,c in pairs(reach.conns) do c:Disconnect() end reach.conns={} for _,c in pairs(reach.hrpConns) do c:Disconnect() end reach.hrpConns={}
	if reach.rPart then local w=reach.rPart:FindFirstChild("ReachWeld") if w then w:Destroy() end reach.rPart:Destroy() reach.rPart=nil end
	if reach.rBox then reach.rBox:Destroy() reach.rBox=nil end reach.tool=nil reach.part=nil
	for _,p in pairs(game.Players:GetPlayers()) do if p~=Player and p.Character then local h=p.Character:FindFirstChild("HumanoidRootPart") if h then h.Size=Vector3.new(2,2,1) h.Transparency=1 h.CanCollide=false end end end
end
local function startReach()
	reach.rPart=Instance.new("Part") reach.rPart.Name="ReachPart" reach.rPart.Anchored=true reach.rPart.CanCollide=false reach.rPart.Transparency=1 reach.rPart.Massless=true reach.rPart.Size=Vector3.new(getXW(),reach.wid,reach.len) reach.rPart.CFrame=CFrame.new(0,-9999,0) reach.rPart.Parent=workspace
	reach.rBox=Instance.new("SelectionBox") reach.rBox.Adornee=reach.rPart reach.rBox.Color3=T.WHITE reach.rBox.LineThickness=0.05 reach.rBox.SurfaceTransparency=0.6 reach.rBox.SurfaceColor3=T.WHITE reach.rBox.Parent=workspace
	local function onRemove(c) if c:IsA("Tool") then reach.tool=nil reach.part=nil local ow=reach.rPart and reach.rPart:FindFirstChild("ReachWeld") if ow then ow:Destroy() end hideRP() end end
	local function onAdd(c) if c:IsA("Tool") then applyToTool(c) end end
	table.insert(reach.conns,Player.CharacterAdded:Connect(function(char) task.wait() table.insert(reach.conns,char.ChildAdded:Connect(onAdd)) table.insert(reach.conns,char.ChildRemoved:Connect(onRemove)) end))
	if Player.Character then
		table.insert(reach.conns,Player.Character.ChildAdded:Connect(onAdd)) table.insert(reach.conns,Player.Character.ChildRemoved:Connect(onRemove))
		for _,c in pairs(Player.Character:GetChildren()) do if c:IsA("Tool") then applyToTool(c) end end
	end
	table.insert(reach.conns,RunService.Heartbeat:Connect(function()
		if not reach.tool or not reach.tool.Parent or not reach.rPart then return end
		local weld=reach.rPart:FindFirstChild("ReachWeld")
		if not weld or not weld.Part1 or not weld.Part1.Parent then attachReachPart() end
	end))
end
