local function settingsToggle(key)
	local sg=panelSettings[key] if not sg then return end
	for _,c in pairs(sg:GetChildren()) do
		if c:IsA("Frame") then
			if c.Visible then tw(c,{BackgroundTransparency=1}) task.wait(0.15) c.Visible=false c.BackgroundTransparency=0.05
			else c.BackgroundTransparency=1 c.Visible=true tw(c,{BackgroundTransparency=0.05}) end break
		end
	end
end

