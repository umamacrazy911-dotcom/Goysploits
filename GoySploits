-- Icy Trials — TP to place if not already there
local function runIcyTrials()
	if game.PlaceId~=17290438723 then
		showToast("Teleporting to Icy Trials...",Color3.fromRGB(200,180,80))
		task.spawn(function()
			local ok,err=pcall(function() TeleportService:Teleport(17290438723,Player) end)
			if not ok then showToast("TP Failed: "..tostring(err):sub(1,30),Color3.fromRGB(200,80,80)) end
		end)
		return
	end
	task.spawn(function()
		local ok,err=pcall(function()
			workspace.FinishDoor_Ice.Model.Part.ProximityPrompt.HoldDuration=0
			local deadline=tick()+5
			while tick()<deadline do
				task.wait(0.1)
				if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then break end
				safeTeleportCFrame(CFrame.new(Vector3.new(-557.204833984375,177.94590759277344,54.048336029052734)))
				fireproximityprompt(workspace.FinishDoor_Ice.Model.Part.ProximityPrompt)
			end
		end)
		if not ok then showToast("Icy Trials: "..tostring(err):sub(1,40),Color3.fromRGB(200,80,80)) end
	end)
end
createScriptButton({key="IcyTrials",label="Icy Trials",runOnce=true,runScript=runIcyTrials},ObtainmentGrid)

