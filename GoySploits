-- =====================
UIS.InputBegan:Connect(function(input,gpe)
	if input.KeyCode==Enum.KeyCode.RightShift then Panel.Visible=not Panel.Visible return end
	if gpe then return end
	if bindingScript then return end
	if binds["EasterEggs"] and input.KeyCode==binds["EasterEggs"] then runEasterEggs() return end
	if binds["IcyTrials"] and input.KeyCode==binds["IcyTrials"] then runIcyTrials() return end
	if binds["PocketDimension"] and input.KeyCode==binds["PocketDimension"] then runPocketDimension() return end
	if binds["AutoPsycho"] and input.KeyCode==binds["AutoPsycho"] then runAutoPsycho() return end
	if binds["TelAviv"] and input.KeyCode==binds["TelAviv"] then doTelAvivTP() return end
	for key,keyCode in pairs(binds) do
		if input.KeyCode==keyCode then
			if key=="MouseTP" then doMouseTP()
			elseif key=="EasterEggs" then runEasterEggs()
			elseif key=="IcyTrials" then runIcyTrials()
			elseif key=="PocketDimension" then runPocketDimension()
			elseif key=="AutoPsycho" then runAutoPsycho()
			elseif key=="TelAviv" then doTelAvivTP()
			else
				local newState=not states[key] states[key]=newState
				if tileRefs[key] then tileRefs[key](newState) end
				toggleFunctions[key](newState)
			end
			break
		end
	end
end)

