local function makeSlider(parent, yOff, minV, maxV, curV, w, xOff, onChange)
	local track = Instance.new("Frame")
	track.Size = UDim2.new(w or 0.9, 0, 0, 6) track.Position = UDim2.new(xOff or 0.05, 0, 0, yOff)
	track.BackgroundColor3 = THEME.BG_MID track.ZIndex = (parent.ZIndex or 50)+1 track.Parent = parent
	addCorner(track, 3) addStroke(track, THEME.STROKE_DIM, 1)
	local fill = Instance.new("Frame") fill.Size = UDim2.new(0,0,1,0) fill.BackgroundColor3 = THEME.GLOW_WHITE fill.ZIndex = track.ZIndex+1 fill.Parent = track
	addCorner(fill, 3)
	local knob = Instance.new("TextButton") knob.Size = UDim2.new(0,12,0,12) knob.AnchorPoint = Vector2.new(0.5,0.5)
	knob.Position = UDim2.new(0,0,0.5,0) knob.BackgroundColor3 = THEME.GLOW_WHITE knob.Text = "" knob.ZIndex = track.ZIndex+2 knob.Parent = track
	addCorner(knob, 6)
	local rel0 = (curV-minV)/(maxV-minV)
	knob.Position = UDim2.new(rel0,0,0.5,0) fill.Size = UDim2.new(rel0,0,1,0)
	local drag = false
	knob.MouseButton1Down:Connect(function() drag=true tw(knob,{Size=UDim2.new(0,15,0,15)}) end)
	UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 and drag then drag=false tw(knob,{Size=UDim2.new(0,12,0,12)}) end end)
	RunService.RenderStepped:Connect(function()
		if drag then
			local rel = math.clamp((UIS:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
			local val = math.round(minV+(maxV-minV)*rel)
			knob.Position = UDim2.new(rel,0,0.5,0) fill.Size = UDim2.new(rel,0,1,0) onChange(val)
		end
	end)
	return track, knob, fill
end

local function makeSwitch(parent, yOff, xRight, defaultOn, onChange)
	local sw = Instance.new("TextButton") sw.Size = UDim2.new(0,36,0,18) sw.Position = UDim2.new(1,xRight or -44,0,yOff)
	sw.BackgroundColor3 = defaultOn and THEME.GLOW_WHITE or THEME.BG_MID sw.Text = "" sw.ZIndex = (parent.ZIndex or 50)+1 sw.Parent = parent
	addCorner(sw, 9) addStroke(sw, defaultOn and THEME.STROKE or THEME.STROKE_DIM, 1)
