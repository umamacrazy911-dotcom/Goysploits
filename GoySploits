		local HomeBtn=Instance.new("TextButton") HomeBtn.Size=UDim2.new(0,20,0,20) HomeBtn.Position=UDim2.new(1,-2,0,2) HomeBtn.AnchorPoint=Vector2.new(1,0)
		HomeBtn.BackgroundColor3=THEME.BG_MID HomeBtn.Text="⌂" HomeBtn.TextColor3=THEME.GLOW_WHITE HomeBtn.TextScaled=true HomeBtn.Font=Enum.Font.GothamBold HomeBtn.ZIndex=15 HomeBtn.Parent=Tile
		addCorner(HomeBtn,4) addStroke(HomeBtn,THEME.STROKE_DIM,1)
		HomeBtn.MouseButton1Click:Connect(function() doTelAvivHomeTP() end)
	end
	local loaded=false
	local function setVisual(on)
		if oneShot then
			tw(StatusLabel,{TextColor3=THEME.GREEN}) StatusLabel.Text="Loaded" tw(TS,{Color=THEME.GREEN})
		elseif key=="TelAviv" then
			tw(StatusLabel,{TextColor3=THEME.GREEN}) StatusLabel.Text="✈ TP'd!" tw(TS,{Color=THEME.GREEN})
			task.delay(2,function() tw(StatusLabel,{TextColor3=THEME.STROKE_DIM}) StatusLabel.Text="Click to Go" tw(TS,{Color=THEME.STROKE_DIM}) end)
		elseif runOnce then
			tw(StatusLabel,{TextColor3=THEME.GREEN}) StatusLabel.Text="✓ Ran!" tw(TS,{Color=THEME.GREEN})
			task.delay(1.5,function() tw(StatusLabel,{TextColor3=THEME.STROKE_DIM}) StatusLabel.Text="Click to Run" tw(TS,{Color=THEME.STROKE_DIM}) end)
		else
			StatusLabel.Text = on and "ON" or "OFF"
			tw(StatusLabel,{TextColor3 = on and THEME.GREEN or THEME.STROKE_DIM})
			tw(TS,{Color = on and THEME.STROKE or THEME.STROKE_DIM})
			tw(Tile,{BackgroundColor3 = on and Color3.fromRGB(18,20,18) or THEME.BG_TILE})
		end
	end
	if not runOnce and key~="TelAviv" then tileRefs[key]=setVisual end
	local function doAction()
		if key=="TelAviv" then doTelAvivTP() setVisual(true)
		elseif runOnce then if data.runScript then data.runScript() end setVisual(true)
		elseif oneShot then if not loaded then loaded=true setVisual(true) toggleFunctions[key](true) end
		else
			local newState=not states[key] states[key]=newState setVisual(newState) toggleFunctions[key](newState)
		end
	end
	ClickZone.MouseButton1Click:Connect(doAction)
	BindLabel.MouseButton1Click:Connect(function()
		if bindingScript then return end
		bindingScript=key BindLabel.Text="press a key..." tw(BindLabel,{TextColor3=THEME.GLOW_WHITE})
		local conn conn=UIS.InputBegan:Connect(function(input,gpe)
			if input.UserInputType==Enum.UserInputType.Keyboard then
				if input.KeyCode==binds[key] then task.wait() binds[key]=nil BindLabel.Text="click to bind" tw(BindLabel,{TextColor3=THEME.STROKE_DIM}) bindingScript=nil conn:Disconnect()
				else task.wait() binds[key]=input.KeyCode BindLabel.Text=input.KeyCode.Name tw(BindLabel,{TextColor3=THEME.GLOW_DIM}) bindingScript=nil conn:Disconnect() end
			end
		end)
	end)
end

