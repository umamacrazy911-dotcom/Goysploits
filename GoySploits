local function makeFloatingFrame(w, h, posX, posY)
	local f = Instance.new("Frame")
	f.Size = UDim2.new(w, 0, h, 0)
	f.Position = UDim2.new(posX, 0, posY, 0)
	f.BackgroundColor3 = THEME.BG_FLOATING
	f.BackgroundTransparency = THEME.FLOAT_TRANS
	f.ClipsDescendants = true
	addCorner(f, 8)
	addStroke(f, THEME.STROKE, 1.2)
	return f
end

