	gyro.MaxTorque=Vector3.new(1e6,1e6,1e6) gyro.CFrame=root.CFrame gyro.Parent=root
	local vel=Instance.new("BodyVelocity") vel.Name="SFFlightVelocity" vel.Velocity=Vector3.new(0,0,0) vel.MaxForce=Vector3.new(1e6,1e6,1e6) vel.Parent=root
end
local function sfDisableFlight(char)
	local root=char and char:FindFirstChild("HumanoidRootPart") if not root then return end
	local hum=char:FindFirstChild("Humanoid") if hum then hum.PlatformStand=false end
	if root:FindFirstChild("SFFlightGyro") then root:FindFirstChild("SFFlightGyro"):Destroy() end
	if root:FindFirstChild("SFFlightVelocity") then root:FindFirstChild("SFFlightVelocity"):Destroy() end
end
local function sfHasRockGlove(p)
	local ls=game.Players:FindFirstChild(p.Name) if not ls then return false end
	local leaderstats=ls:FindFirstChild("leaderstats") if not leaderstats then return false end
	local glove=leaderstats:FindFirstChild("Glove") if not glove then return false end
	for _,rg in pairs(SF_ROCK_GLOVES) do if glove.Value==rg then return true end end return false
end
local function sfPassesFilters(p)
	local hrp=sfGetHRP()
	local pHasTool=(p.Character and p.Character:FindFirstChildOfClass("Tool")) or p.Backpack:FindFirstChildOfClass("Tool")
	if not pHasTool then return false end
	local pHRP=p.Character and p.Character:FindFirstChild("HumanoidRootPart") if not pHRP then return false end
	if sfListMode=="Whitelist" then if not sfSelectedPlayers[p.Name] then return false end
	elseif sfListMode=="Blacklist" then if sfSelectedPlayers[p.Name] then return false end end
	if sfIgnoreVoid and pHRP.Position.Y<-15 then return false end
	if sfIgnoreRock and sfHasRockGlove(p) then return false end
	if sfIgnoreLongDistance and hrp then if (pHRP.Position-hrp.Position).Magnitude>1500 then return false end end
	if sfIgnoreFriends and Player:IsFriendsWith(p.UserId) then return false end
	return true
end
local function sfGetTargets()
	local hrp=sfGetHRP() local valid={}
	for _,p in pairs(game.Players:GetPlayers()) do
		if p==Player then continue end if not p.Character then continue end if sfPassesFilters(p) then table.insert(valid,p) end
	end
	if sfTargetMode=="Nearest Player" and hrp and #valid>0 then
		local nearest,nearestDist=nil,math.huge
		for _,p in pairs(valid) do local pHRP=p.Character:FindFirstChild("HumanoidRootPart") if pHRP then local d=(pHRP.Position-hrp.Position).Magnitude if d<nearestDist then nearestDist=d nearest=p end end end
		return nearest and {nearest} or {}
	elseif sfTargetMode=="Nearest Alternate" and hrp and #valid>0 then
		table.sort(valid,function(a,b)
			local aH=a.Character:FindFirstChild("HumanoidRootPart") local bH=b.Character:FindFirstChild("HumanoidRootPart")
			if not aH then return false end if not bH then return true end
			return (aH.Position-hrp.Position).Magnitude<(bH.Position-hrp.Position).Magnitude
		end)
		for _,p in ipairs(valid) do if p~=sfLastTarget then return {p} end end return {valid[1]}
	end
	return valid
end
local function sfSlapFarm()
	local char=sfGetCharacter() local tool=char and char:FindFirstChildOfClass("Tool") if not tool then return end
	local clone=tool:Clone() tool:Destroy() clone.Parent=Player.Backpack task.wait() char.Humanoid:EquipTool(clone) task.wait()
	local animator=char.Humanoid:FindFirstChild("Animator")
	if animator then
		for _,track in pairs(animator:GetPlayingAnimationTracks()) do
			if track.Animation and not track.Animation.AnimationId:find("913376220") then track:Stop() end
		end
	end
	local newTool=char:FindFirstChildOfClass("Tool")
	if newTool then for _,part in pairs(newTool:GetDescendants()) do if part:IsA("BasePart") then part.Size=Vector3.new(20,20,20) part.Transparency=1 end end newTool:Activate() end
end
