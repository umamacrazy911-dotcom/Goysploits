		if mini then btn.Text="+" tw(frame,{Size=UDim2.new(orig.X.Scale,orig.X.Offset,0,tbH)},TW_M) task.wait(0.05) for _,c in ipairs(items) do if c and c~=title and c~=btn and c.Parent==frame then c.Visible=false end end
