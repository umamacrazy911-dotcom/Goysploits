local function sfEnableFlight(char)
	local root=char:FindFirstChild("HumanoidRootPart") if not root then return end
	local hum=char:FindFirstChild("Humanoid") if hum then hum.PlatformStand=true end
	if root:FindFirstChild("SFFlightGyro") then root:FindFirstChild("SFFlightGyro"):Destroy() end
