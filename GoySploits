local telAvivIslandParts = {}
local TEL_AVIV_ORIGIN = Vector3.new(10000, 50, 10000)

local function buildTelAvivIsland()
    for _, p in ipairs(telAvivIslandParts) do
        if p and p.Parent then p:Destroy() end
    end
    telAvivIslandParts = {}

    local function addPart(size, pos, color, material, anchored)
        local p = Instance.new("Part")
        p.Size = size
        p.CFrame = CFrame.new(TEL_AVIV_ORIGIN + pos)
        p.Color = color
        p.Material = material or Enum.Material.SmoothPlastic
        p.Anchored = anchored ~= false
        p.CanCollide = true
        p.Parent = workspace
        table.insert(telAvivIslandParts, p)
        return p
    end

    -- Main island base (sand)
    addPart(Vector3.new(120, 6, 120), Vector3.new(0, -3, 0), Color3.fromRGB(237, 210, 150), Enum.Material.Sandstone)

    -- Grass top layer
    addPart(Vector3.new(120, 2, 120), Vector3.new(0, 1, 0), Color3.fromRGB(106, 175, 90), Enum.Material.Grass)

    -- Water around island
    for _, offset in ipairs({
        {Vector3.new(160, 2, 40), Vector3.new(-140, -3, 0)},
        {Vector3.new(160, 2, 40), Vector3.new(140, -3, 0)},
        {Vector3.new(40, 2, 160), Vector3.new(0, -3, -140)},
        {Vector3.new(40, 2, 160), Vector3.new(0, -3, 140)},
    }) do
        addPart(offset[1], offset[2], Color3.fromRGB(0, 120, 190), Enum.Material.Glass)
    end

    -- Central white stone path
    addPart(Vector3.new(8, 0.5, 80), Vector3.new(0, 2.5, 0), Color3.fromRGB(240, 240, 240), Enum.Material.Concrete)

    -- Fountain base
    addPart(Vector3.new(16, 2, 16), Vector3.new(0, 3, 0), Color3.fromRGB(220, 220, 220), Enum.Material.Marble)
    -- Fountain water
    addPart(Vector3.new(10, 1, 10), Vector3.new(0, 4.5, 0), Color3.fromRGB(100, 180, 220), Enum.Material.Glass)
    -- Fountain center spire
    addPart(Vector3.new(2, 6, 2), Vector3.new(0, 8, 0), Color3.fromRGB(200, 200, 200), Enum.Material.Marble)

    -- Palm trees (4 corners)
    for _, offset in ipairs({
        Vector3.new(40, 0, 40), Vector3.new(-40, 0, 40),
        Vector3.new(40, 0, -40), Vector3.new(-40, 0, -40)
    }) do
        -- trunk
        local trunk = addPart(Vector3.new(2, 16, 2), offset + Vector3.new(0, 10, 0), Color3.fromRGB(120, 80, 40), Enum.Material.Wood)
        trunk.Shape = Enum.PartType.Cylinder
        -- leaves
        addPart(Vector3.new(16, 3, 16), offset + Vector3.new(0, 19, 0), Color3.fromRGB(60, 140, 50), Enum.Material.Grass)
    end

    -- White buildings (left side)
    for i = 1, 3 do
        local bx = -45
        local bz = -30 + (i-1) * 30
        addPart(Vector3.new(14, 18 + i*4, 14), Vector3.new(bx, 10 + i*2, bz), Color3.fromRGB(245, 245, 245), Enum.Material.SmoothPlastic)
        -- blue roof stripe
        addPart(Vector3.new(14, 2, 14), Vector3.new(bx, 20 + i*4, bz), Color3.fromRGB(0, 56, 184), Enum.Material.SmoothPlastic)
    end

    -- White buildings (right side)
    for i = 1, 3 do
        local bx = 45
        local bz = -30 + (i-1) * 30
        addPart(Vector3.new(14, 14 + i*4, 14), Vector3.new(bx, 8 + i*2, bz), Color3.fromRGB(245, 245, 245), Enum.Material.SmoothPlastic)
        addPart(Vector3.new(14, 2, 14), Vector3.new(bx, 16 + i*4, bz), Color3.fromRGB(0, 56, 184), Enum.Material.SmoothPlastic)
    end

    -- =====================
    -- Israeli Flag (flagpole + flag)
    -- =====================
    -- Pole
    local pole = addPart(Vector3.new(1, 40, 1), Vector3.new(-55, 22, -55), Color3.fromRGB(180, 180, 180), Enum.Material.Metal)
    pole.Shape = Enum.PartType.Cylinder
    pole.CFrame = CFrame.new(TEL_AVIV_ORIGIN + Vector3.new(-55, 22, -55)) * CFrame.Angles(0, 0, math.rad(90))
    pole.CFrame = CFrame.new(TEL_AVIV_ORIGIN + Vector3.new(-55, 22, -55))

    -- Flag white background
    addPart(Vector3.new(0.3, 20, 36), Vector3.new(-54.7, 30, -55), Color3.fromRGB(255, 255, 255), Enum.Material.SmoothPlastic)

    -- Top blue stripe
    addPart(Vector3.new(0.3, 4, 36), Vector3.new(-54.7, 38, -55), Color3.fromRGB(0, 56, 184), Enum.Material.SmoothPlastic)

    -- Bottom blue stripe
    addPart(Vector3.new(0.3, 4, 36), Vector3.new(-54.7, 22, -55), Color3.fromRGB(0, 56, 184), Enum.Material.SmoothPlastic)

    -- Star of David (center) — approximated with two triangles as wedges
    -- Top triangle wedge
    local star1 = Instance.new("WedgePart")
    star1.Size = Vector3.new(0.3, 7, 8)
    star1.CFrame = CFrame.new(TEL_AVIV_ORIGIN + Vector3.new(-54.7, 30, -55)) * CFrame.Angles(0, 0, 0)
    star1.Color = Color3.fromRGB(0, 56, 184)
    star1.Material = Enum.Material.SmoothPlastic
    star1.Anchored = true
    star1.CanCollide = false
    star1.Parent = workspace
    table.insert(telAvivIslandParts, star1)

    -- Bottom triangle wedge (inverted)
    local star2 = Instance.new("WedgePart")
    star2.Size = Vector3.new(0.3, 7, 8)
    star2.CFrame = CFrame.new(TEL_AVIV_ORIGIN + Vector3.new(-54.7, 30, -55)) * CFrame.Angles(0, math.rad(180), math.rad(180))
    star2.Color = Color3.fromRGB(0, 56, 184)
    star2.Material = Enum.Material.SmoothPlastic
    star2.Anchored = true
    star2.CanCollide = false
    star2.Parent = workspace
    table.insert(telAvivIslandParts, star2)

    -- Stone plaza at base of flag
    addPart(Vector3.new(20, 1, 20), Vector3.new(-55, 2.5, -55), Color3.fromRGB(210, 200, 185), Enum.Material.Cobblestone)

    -- Benches around plaza
    for _, bOffset in ipairs({Vector3.new(-8, 0, 0), Vector3.new(8, 0, 0), Vector3.new(0, 0, -8), Vector3.new(0, 0, 8)}) do
        addPart(Vector3.new(6, 1.5, 2), Vector3.new(-55, 4, -55) + bOffset, Color3.fromRGB(140, 100, 60), Enum.Material.Wood)
    end

    -- Decorative flower beds (blue and white)
    for _, fOffset in ipairs({
        {Vector3.new(0, 0, 30), Color3.fromRGB(0, 56, 184)},
        {Vector3.new(0, 0, -30), Color3.fromRGB(255, 255, 255)},
        {Vector3.new(30, 0, 0), Color3.fromRGB(0, 56, 184)},
        {Vector3.new(-30, 0, 0), Color3.fromRGB(255, 255, 255)},
    }) do
        addPart(Vector3.new(10, 1, 10), fOffset[1] + Vector3.new(0, 2.5, 0), fOffset[2], Enum.Material.Neon)
    end
end

local function destroyTelAvivIsland()
    for _, p in ipairs(telAvivIslandParts) do
        if p and p.Parent then p:Destroy() end
    end
    telAvivIslandParts = {}
end

local telAvivActive = false

local function startTelAviv()
    telAvivActive = true
    buildTelAvivIsland()
end

local function stopTelAviv()
    telAvivActive = false
    destroyTelAvivIsland()
end

local function doTelAvivTP()
    if not telAvivActive then return end
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = CFrame.new(TEL_AVIV_ORIGIN + Vector3.new(0, 10, 0))
    end
end

