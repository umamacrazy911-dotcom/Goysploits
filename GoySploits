	knob.BackgroundColor3 = defaultOn and THEME.BG_DARK or THEME.GLOW_DIM knob.ZIndex = sw.ZIndex+1 knob.Parent = sw
	addCorner(knob, 7)
	local state = defaultOn
	sw.MouseButton1Click:Connect(function()
		state = not state
