local fc={active=false,speed=50,tpOnStop=false}
local fcConn=nil local fcMouseConn=nil local fcYaw=0 local fcPitch=0
local function stopFreecam()
	fc.active=false
	if fcConn then fcConn:Disconnect() fcConn=nil end
	if fcMouseConn then fcMouseConn:Disconnect() fcMouseConn=nil end
	UIS.MouseBehavior=Enum.MouseBehavior.Default
	local cam=workspace.CurrentCamera cam.CameraType=Enum.CameraType.Custom
	local char=Player.Character
	if char then local hum=char:FindFirstChild("Humanoid") if hum then cam.CameraSubject=hum end if fc.tpOnStop and char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.CFrame=cam.CFrame end end
end
local function startFreecam()
	fc.active=true
	local cam=workspace.CurrentCamera
	local camPos=cam.CFrame.Position
	local cf=cam.CFrame
	fcYaw=math.atan2(-cf.LookVector.X,-cf.LookVector.Z)
	fcPitch=math.asin(math.clamp(cf.LookVector.Y,-1,1))
	cam.CameraType=Enum.CameraType.Scriptable
	UIS.MouseBehavior=Enum.MouseBehavior.LockCenter
	fcMouseConn=UIS.InputChanged:Connect(function(input)
		if not fc.active then return end
		if input.UserInputType==Enum.UserInputType.MouseMovement then
			local sens=0.003
			fcYaw=fcYaw-input.Delta.X*sens
			fcPitch=math.clamp(fcPitch-input.Delta.Y*sens,-math.rad(89),math.rad(89))
		end
	end)
	fcConn=RunService.RenderStepped:Connect(function(dt)
		if not fc.active then return end
		local rot=CFrame.Angles(0,fcYaw,0)*CFrame.Angles(fcPitch,0,0)
		local look=rot.LookVector local right=rot.RightVector
		local spd=fc.speed*(UIS:IsKeyDown(Enum.KeyCode.LeftShift) and 3 or 1)*dt
		local dv=Vector3.new(0,0,0)
		if UIS:IsKeyDown(Enum.KeyCode.W) then dv=dv+look*spd end
		if UIS:IsKeyDown(Enum.KeyCode.S) then dv=dv-look*spd end
		if UIS:IsKeyDown(Enum.KeyCode.A) then dv=dv-right*spd end
		if UIS:IsKeyDown(Enum.KeyCode.D) then dv=dv+right*spd end
		if UIS:IsKeyDown(Enum.KeyCode.E) then dv=dv+Vector3.new(0,1,0)*spd end
		if UIS:IsKeyDown(Enum.KeyCode.Q) then dv=dv-Vector3.new(0,1,0)*spd end
		camPos=camPos+dv
		cam.CFrame=CFrame.new(camPos)*CFrame.Angles(0,fcYaw,0)*CFrame.Angles(fcPitch,0,0)
		if cam.CameraType~=Enum.CameraType.Scriptable then cam.CameraType=Enum.CameraType.Scriptable end
		local char=Player.Character if char then local hum=char:FindFirstChild("Humanoid") if hum then hum:Move(Vector3.new(0,0,0),false) end end
	end)
end
