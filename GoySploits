local sfWalkAnimTrack=nil local SF_WALK_ANIM="rbxassetid://913376220"
local function sfLoadWalkAnim()
	local char=sfGetCharacter() if not char then return end local hum=char:FindFirstChild("Humanoid") if not hum then return end
	local animator=hum:FindFirstChildOfClass("Animator") if not animator then return end
	if sfWalkAnimTrack and sfWalkAnimTrack.IsPlaying then return end
	local anim=Instance.new("Animation") anim.AnimationId=SF_WALK_ANIM
	sfWalkAnimTrack=animator:LoadAnimation(anim) sfWalkAnimTrack.Priority=Enum.AnimationPriority.Action sfWalkAnimTrack.Looped=true sfWalkAnimTrack:Play()
end
local function sfStopWalkAnim() if sfWalkAnimTrack then if sfWalkAnimTrack.IsPlaying then sfWalkAnimTrack:Stop() end sfWalkAnimTrack=nil end end
local sfArmHoldConn=nil
local function sfStartArmHold()
	if sfArmHoldConn then return end
	sfArmHoldConn=RunService.RenderStepped:Connect(function()
		if not sfWalkMode or not slapFarmActive then return end
		local char=sfGetCharacter() if not char then return end local tool=char:FindFirstChildOfClass("Tool") if not tool then return end
		local torso=char:FindFirstChild("Torso")
		if torso then local rs=torso:FindFirstChild("Right Shoulder") if rs then rs.C0=CFrame.new(1,0.5,0)*CFrame.Angles(math.rad(-90),math.rad(90),math.rad(90)) end
		else local ut=char:FindFirstChild("UpperTorso") if ut then local rs=ut:FindFirstChild("RightShoulder") if rs then rs.C0=CFrame.new(rs.C0.Position)*CFrame.Angles(math.rad(-90),0,0) end end end
	end)
end
local function sfStopArmHold()
	if sfArmHoldConn then sfArmHoldConn:Disconnect() sfArmHoldConn=nil end
	local char=sfGetCharacter() if not char then return end local torso=char:FindFirstChild("Torso")
	if torso then local rs=torso:FindFirstChild("Right Shoulder") if rs then rs.C0=CFrame.new(1,0.5,0,0,0,1,0,1,0,-1,0,0) end
	else local ut=char:FindFirstChild("UpperTorso") if ut then local rs=ut:FindFirstChild("RightShoulder") if rs then rs.C0=CFrame.new(1,0.5,0) end end end
end
local function sfStopWalkMovement()
	if sfWalkMoveConn then sfWalkMoveConn:Disconnect() sfWalkMoveConn=nil end
	sfWalkIsMoving=false sfStopWalkAnim() sfStopArmHold()
	local char=sfGetCharacter() local hrp=sfGetHRP() if char and char:FindFirstChild("Humanoid") and hrp then char.Humanoid:MoveTo(hrp.Position) end
end
local function sfBeginWalkToTarget(p)
	if sfWalkMoveConn then sfWalkMoveConn:Disconnect() sfWalkMoveConn=nil end sfWalkIsMoving=true
	local char=sfGetCharacter() local hum=char and char:FindFirstChild("Humanoid") if not hum then sfWalkIsMoving=false return end
	sfLoadWalkAnim() sfStartArmHold()
	sfWalkMoveConn=RunService.Heartbeat:Connect(function()
		if not sfWalkIsMoving then sfWalkMoveConn:Disconnect() sfWalkMoveConn=nil return end
		local pChar=p.Character if not pChar then sfWalkIsMoving=false return end
		local pHRP=pChar:FindFirstChild("HumanoidRootPart") if not pHRP then sfWalkIsMoving=false return end
		local hum2=sfGetCharacter() and sfGetCharacter():FindFirstChild("Humanoid") if hum2 then hum2:MoveTo(pHRP.Position) end
	end)
end
local function startSlapFarm()
	slapFarmActive=true
	sfFlightConnection=RunService.RenderStepped:Connect(function()
		if sfWalkMode then return end local hrp=sfGetHRP() if not hrp or not sfFlightEnabled then return end
		local vel=hrp:FindFirstChild("SFFlightVelocity") local gyro=hrp:FindFirstChild("SFFlightGyro") if not vel or not gyro then return end
		if sfTargetToFollow and sfTargetToFollow.Character and sfTargetToFollow.Character:FindFirstChild("HumanoidRootPart") then
			local tHRP=sfTargetToFollow.Character.HumanoidRootPart local diff=(tHRP.Position+Vector3.new(0,10,0))-hrp.Position local dist=diff.Magnitude
			if dist>1 then vel.Velocity=diff.Unit*math.min(dist*20,sfFlightSpeed) else vel.Velocity=Vector3.new(0,0,0) end gyro.CFrame=CFrame.new(hrp.Position,tHRP.Position)
		else vel.Velocity=Vector3.new(0,0,0) gyro.CFrame=CFrame.new(hrp.Position) end
	end)
	sfSteppedConnection=RunService.Stepped:Connect(function()
		local char=sfGetCharacter() if char and sfFlightEnabled and not sfWalkMode then for _,part in pairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide=false end end end
	end)
	task.spawn(function()
		while slapFarmActive do
			task.wait(0.1) local char=sfGetCharacter() local hrp=sfGetHRP() local toolExists=sfHasTool()
			if sfWalkMode then
				if not toolExists then sfStopWalkMovement() if hrp then safeTeleportCFrame(SPAWN_CFRAME) end continue end
				local tool=char and char:FindFirstChildOfClass("Tool") local myTool=tool or Player.Backpack:FindFirstChildOfClass("Tool")
				if not tool and myTool and char and char:FindFirstChild("Humanoid") then char.Humanoid:EquipTool(myTool) task.wait(0.1) tool=char:FindFirstChildOfClass("Tool") end
				local targets=sfGetTargets() if #targets==0 then sfStopWalkMovement() continue end
				local p=targets[1] if not sfPassesFilters(p) then sfStopWalkMovement() continue end
				sfLastTarget=p sfTargetToFollow=p sfBeginWalkToTarget(p)
				local timeout=tick()+5
				repeat task.wait(0.05) if not slapFarmActive or not sfWalkMode then break end
					local pHRP2=p.Character and p.Character:FindFirstChild("HumanoidRootPart") if not pHRP2 or not sfPassesFilters(p) then break end if hrp and (pHRP2.Position-hrp.Position).Magnitude<6 then break end
				until tick()>timeout
				if sfWalkMoveConn then sfWalkMoveConn:Disconnect() sfWalkMoveConn=nil end sfWalkIsMoving=false
				tool=char and char:FindFirstChildOfClass("Tool")
				if tool then tool:Activate() if sfAntiKick then task.wait(1) else task.wait(0.1) end sfSlapFarm() task.wait(0.1) end sfTargetToFollow=nil
			else
				sfStopWalkMovement()
				if not toolExists then if sfFlightEnabled then sfFlightEnabled=false sfTargetToFollow=nil sfDisableFlight(char) end if hrp then safeTeleportCFrame(SPAWN_CFRAME) end continue end
				if not sfFlightEnabled then sfFlightEnabled=true sfEnableFlight(char) end
				local tool=char and char:FindFirstChildOfClass("Tool") local myTool=tool or Player.Backpack:FindFirstChildOfClass("Tool")
				if not tool and myTool then char.Humanoid:EquipTool(myTool) task.wait(0.1) end
				local targets=sfGetTargets() if #targets==0 then sfTargetToFollow=nil continue end
				for _,p in pairs(targets) do
					if not sfPassesFilters(p) then continue end sfTargetToFollow=p sfLastTarget=p local followEnd=tick()+2
					while tick()<followEnd do
						if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then break end if not sfPassesFilters(p) then sfTargetToFollow=nil break end
						tool=char and char:FindFirstChildOfClass("Tool") if tool then tool:Activate() task.wait(1.5) sfSlapFarm() task.wait(0.1) else break end
					end
					if sfAntiKick then task.wait(1) end
				end sfTargetToFollow=nil
			end
		end
	end)
end
local function stopSlapFarm()
	slapFarmActive=false sfFlightEnabled=false sfTargetToFollow=nil sfLastTarget=nil sfStopWalkMovement()
	if sfFlightConnection then sfFlightConnection:Disconnect() sfFlightConnection=nil end
	if sfSteppedConnection then sfSteppedConnection:Disconnect() sfSteppedConnection=nil end
	local char=sfGetCharacter() if char then sfDisableFlight(char) if char:FindFirstChild("Humanoid") then char.Humanoid:MoveTo(char.HumanoidRootPart and char.HumanoidRootPart.Position or Vector3.new(0,0,0)) end end
	sfSpeedSliderRef=nil sfSpeedBoxRef=nil sfSpeedKnobRef=nil
end
