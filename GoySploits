local function sfRockGlove(p) local ls=game.Players:FindFirstChild(p.Name) if not ls then return false end local ld=ls:FindFirstChild("leaderstats") if not ld then return false end local g=ld:FindFirstChild("Glove") if not g then return false end for _,rg in pairs(SF_ROCKS) do if g.Value==rg then return true end end return false end
local function sfFilters(p)
	local hrp=sfHRP() local pHasTool=(p.Character and p.Character:FindFirstChildOfClass("Tool")) or p.Backpack:FindFirstChildOfClass("Tool")
	if not pHasTool then return false end local pHRP=p.Character and p.Character:FindFirstChild("HumanoidRootPart") if not pHRP then return false end
	if sf.listMode=="Whitelist" then if not sf.selPlayers[p.Name] then return false end elseif sf.selPlayers[p.Name] then return false end
	if sf.ignVoid and pHRP.Position.Y<-15 then return false end if sf.ignRock and sfRockGlove(p) then return false end if sf.ignFar and hrp and (pHRP.Position-hrp.Position).Magnitude>1500 then return false end if sf.ignFriends and Player:IsFriendsWith(p.UserId) then return false end
	return true
end
local function sfTargets()
	local hrp=sfHRP() local valid={}
	for _,p in pairs(game.Players:GetPlayers()) do if p==Player then continue end if not p.Character then continue end if sfFilters(p) then table.insert(valid,p) end end
	if sf.targetMode=="Nearest Player" and hrp and #valid>0 then local near,nd=nil,math.huge for _,p in pairs(valid) do local ph=p.Character:FindFirstChild("HumanoidRootPart") if ph then local d=(ph.Position-hrp.Position).Magnitude if d<nd then nd=d near=p end end end return near and {near} or {}
	elseif sf.targetMode=="Nearest Alternate" and hrp and #valid>0 then table.sort(valid,function(a,b) local aH=a.Character:FindFirstChild("HumanoidRootPart") local bH=b.Character:FindFirstChild("HumanoidRootPart") if not aH then return false end if not bH then return true end return (aH.Position-hrp.Position).Magnitude<(bH.Position-hrp.Position).Magnitude end) for _,p in ipairs(valid) do if p~=sf.lastTarget then return {p} end end return {valid[1]} end
	return valid
end
