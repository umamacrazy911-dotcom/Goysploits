	local Tile=Instance.new("Frame") Tile.BackgroundColor3=Color3.fromRGB(40,40,40) Tile.ZIndex=10 Tile.Parent=grid
	local TC=Instance.new("UICorner") TC.CornerRadius=UDim.new(0.08,0) TC.Parent=Tile
	local TS=Instance.new("UIStroke") TS.Color=Color3.fromRGB(70,70,70) TS.Thickness=2 TS.Parent=Tile

	local NameLabel=Instance.new("TextLabel") NameLabel.Size=UDim2.new(1,0,0.45,0) NameLabel.Position=UDim2.new(0,0,0.08,0)
	NameLabel.BackgroundTransparency=1 NameLabel.Text=label NameLabel.TextColor3=Color3.fromRGB(220,220,220)
	NameLabel.TextScaled=true NameLabel.Font=Enum.Font.GothamBold NameLabel.ZIndex=11 NameLabel.Parent=Tile

	local StatusLabel=Instance.new("TextLabel") StatusLabel.Size=UDim2.new(1,0,0.2,0) StatusLabel.Position=UDim2.new(0,0,0.5,0)
	StatusLabel.BackgroundTransparency=1 StatusLabel.Text=oneShot and "Click to Load" or (runOnce and "Click to Run" or "OFF")
	StatusLabel.TextColor3=Color3.fromRGB(150,150,150) StatusLabel.TextScaled=true StatusLabel.Font=Enum.Font.Gotham StatusLabel.ZIndex=11 StatusLabel.Parent=Tile

	local BindLabel=Instance.new("TextButton") BindLabel.Size=UDim2.new(0.85,0,0.22,0) BindLabel.Position=UDim2.new(0.5,0,0.76,0)
	BindLabel.AnchorPoint=Vector2.new(0.5,0) BindLabel.BackgroundColor3=Color3.fromRGB(30,30,30) BindLabel.Text="click to bind"
	BindLabel.TextColor3=Color3.fromRGB(120,120,120) BindLabel.TextScaled=true BindLabel.Font=Enum.Font.Gotham BindLabel.ZIndex=12 BindLabel.Parent=Tile
	local BLC=Instance.new("UICorner") BLC.CornerRadius=UDim.new(0.3,0) BLC.Parent=BindLabel

	local ClickZone=Instance.new("TextButton") ClickZone.Size=UDim2.new(1,0,0.75,0) ClickZone.Position=UDim2.new(0,0,0,0)
	ClickZone.BackgroundTransparency=1 ClickZone.Text="" ClickZone.ZIndex=13 ClickZone.Parent=Tile

	if data.hoverWarning then
		local tooltip=Instance.new("Frame") tooltip.Size=UDim2.new(0,170,0,32) tooltip.AnchorPoint=Vector2.new(0.5,1)
		tooltip.BackgroundColor3=Color3.fromRGB(60,30,30) tooltip.BackgroundTransparency=0.1 tooltip.Visible=false tooltip.ZIndex=20 tooltip.Parent=ScreenGui
		local ttc=Instance.new("UICorner") ttc.CornerRadius=UDim.new(0.15,0) ttc.Parent=tooltip
		local tts=Instance.new("UIStroke") tts.Color=Color3.fromRGB(200,80,80) tts.Thickness=1 tts.Parent=tooltip
		local ttl=Instance.new("TextLabel") ttl.Size=UDim2.new(1,0,1,0) ttl.BackgroundTransparency=1 ttl.Text=data.hoverWarning
		ttl.TextColor3=Color3.fromRGB(255,180,180) ttl.TextScaled=true ttl.Font=Enum.Font.GothamBold ttl.ZIndex=21 ttl.Parent=tooltip
		ClickZone.MouseEnter:Connect(function()
			tooltip.Visible=true
			local ap=Tile.AbsolutePosition local as=Tile.AbsoluteSize
			tooltip.Position=UDim2.fromOffset(ap.X+as.X/2, ap.Y-4)
		end)
		ClickZone.MouseLeave:Connect(function() tooltip.Visible=false end)
	end

	if panelConfigurable[key] then
		local GearBtn=Instance.new("TextButton") GearBtn.Size=UDim2.new(0,20,0,20)
		GearBtn.Position=UDim2.new(1,-2,0,2) GearBtn.AnchorPoint=Vector2.new(1,0)
		GearBtn.BackgroundColor3=Color3.fromRGB(55,55,60) GearBtn.Text="⚙"
		GearBtn.TextColor3=Color3.fromRGB(200,200,200) GearBtn.TextScaled=true GearBtn.Font=Enum.Font.GothamBold GearBtn.ZIndex=15 GearBtn.Parent=Tile
		local GBC=Instance.new("UICorner") GBC.CornerRadius=UDim.new(0.3,0) GBC.Parent=GearBtn
		GearBtn.MouseButton1Click:Connect(function()
			local sg=panelSettingsScreens[key]
			if sg then for _,c in pairs(sg:GetChildren()) do if c:IsA("Frame") then c.Visible=not c.Visible break end end end
		end)
	end

	local loaded=false
	local function setVisual(on)
		if oneShot then StatusLabel.Text="Loaded" StatusLabel.TextColor3=Color3.fromRGB(100,200,100) TS.Color=Color3.fromRGB(100,200,100)
		elseif runOnce then
			StatusLabel.Text="✓ Ran!" StatusLabel.TextColor3=Color3.fromRGB(100,200,100) TS.Color=Color3.fromRGB(100,200,100)
			task.delay(1.5,function() StatusLabel.Text="Click to Run" StatusLabel.TextColor3=Color3.fromRGB(150,150,150) TS.Color=Color3.fromRGB(70,70,70) end)
		else
			StatusLabel.Text=on and "ON" or "OFF"
			StatusLabel.TextColor3=on and Color3.fromRGB(100,200,100) or Color3.fromRGB(150,150,150)
			TS.Color=on and Color3.fromRGB(100,149,237) or Color3.fromRGB(70,70,70)
		end
	end
	if not runOnce then tileRefs[key]=setVisual end

	local function doAction()
		if runOnce then
			if data.runScript then data.runScript() end setVisual(true)
		elseif oneShot then
			if not loaded then loaded=true setVisual(true) toggleFunctions[key](true) end
		else
			local newState=not states[key] states[key]=newState setVisual(newState) toggleFunctions[key](newState)
		end
	end
	ClickZone.MouseButton1Click:Connect(doAction)

	BindLabel.MouseButton1Click:Connect(function()
		if bindingScript then return end
		bindingScript=key BindLabel.Text="press a key..." BindLabel.TextColor3=Color3.fromRGB(100,149,237)
		local conn
		conn=UIS.InputBegan:Connect(function(input,gpe)
			if input.UserInputType==Enum.UserInputType.Keyboard then
				if input.KeyCode==binds[key] then task.wait() binds[key]=nil BindLabel.Text="click to bind" BindLabel.TextColor3=Color3.fromRGB(120,120,120) bindingScript=nil conn:Disconnect()
				else task.wait() binds[key]=input.KeyCode BindLabel.Text=input.KeyCode.Name BindLabel.TextColor3=Color3.fromRGB(180,180,180) bindingScript=nil conn:Disconnect() end
			end
		end)
	end)
end

